---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  lang?: string;
  ogLocale?: string;
  appendSiteName?: boolean;
}

const {
  title,
  description = 'Yiğiter Orman Ürünleri — Kastamonu Entegre Ana Bayisi, kapı kasası ve pervaz üreticisi, 4 kıtaya ihracatçı.',
  ogImage = '/images/og-default.jpg',
  lang = 'tr',
  ogLocale = 'tr_TR',
  appendSiteName = true,
} = Astro.props;

const siteName = 'Yiğiter Orman Ürünleri';
const fullTitle = appendSiteName
  ? title === siteName
    ? 'Yiğiter Orman Ürünleri | Kapı ve Mobilya Yan Sanayi Tedarikçisi'
    : `${title} | ${siteName}`
  : title;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const absoluteOgImage = new URL(ogImage, Astro.site);
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["Organization", "LocalBusiness", "Store"],
      "name": "Yiğiter Orman Ürünleri",
      "alternateName": "YİGİTER ORMAN ÜRÜN.İNŞ.PAZ.SAN.TİC.LTD.ŞTİ.",
      "url": "https://www.yigiter.com.tr",
      "logo": "https://www.yigiter.com.tr/images/logo.png",
      "image": "https://www.yigiter.com.tr/images/og-default.jpg",
      "description": "Kastamonu Entegre Ana Bayisi, Genç Boya Distribütörü, melamin kapı yüzeyi ithalatçısı, kapı kasası ve pervaz üreticisi. 4 kıtaya düzenli ihracat. 20+ yıllık deneyim.",
      "telephone": "+90 212 670 2025",
      "email": "info@yigiter.com.tr",
      "hasMap": "https://www.google.com/maps/d/viewer?mid=1EeHCH3JvvfbKZnkSh_jbVsem3NgLf-s",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "İkitelli Keresteciler Sitesi, Ziyagökalp Mah., 23. Sokak, 24. Blok No:38/40",
        "addressLocality": "Başakşehir",
        "addressRegion": "İstanbul",
        "postalCode": "34490",
        "addressCountry": "TR"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
          "opens": "08:30",
          "closes": "18:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Saturday",
          "opens": "08:30",
          "closes": "15:00"
        }
      ],
      "areaServed": [
        { "@type": "Country", "name": "Turkey" },
        { "@type": "Place", "name": "Avrupa" },
        { "@type": "Place", "name": "Orta Doğu" },
        { "@type": "Place", "name": "Afrika" }
      ],
      "knowsAbout": [
        "Kapı kasası üretimi",
        "Kapı pervazı üretimi",
        "MDF panel",
        "Yongalevha",
        "Melamin kapı yüzeyi",
        "Genç Boya",
        "Kastamonu Entegre"
      ],
      "contactPoint": [
        {
          "@type": "ContactPoint",
          "contactType": "Export",
          "email": "export@yigiter.com.tr",
          "areaServed": ["Europe", "Middle East", "Central Asia", "Africa"]
        }
      ],
      "sameAs": [
        "https://www.google.com/maps/d/viewer?mid=1EeHCH3JvvfbKZnkSh_jbVsem3NgLf-s"
      ]
    })} />


    <title>{fullTitle}</title>

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Microsoft Clarity -->
    <script type="text/javascript">
      (function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
      t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
      y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window,document,"clarity","script","xirpsgg0ls");
    </script>
  </head>
  <body class="font-sans bg-white text-neutral-800 antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <Analytics />
    <SpeedInsights />
  </body>
</html>
