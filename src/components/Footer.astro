---
const currentYear = new Date().getFullYear();

const footerLinks = [
  {
    title: 'Ürünler',
    links: [
      { label: 'Kastamonu Entegre', href: '/urunler/kastamonu-entegre' },
      { label: 'Genç Boya', href: '/urunler/genc-boya' },
      { label: 'Melamin Kapı Yüzeyleri', href: '/urunler/melamin-kapi-yuzeyi' },
      { label: 'Kapı Komponentleri', href: '/urunler/kapi-komponentleri' },
      { label: 'Kapı İmalat Malzemeleri', href: '/urunler/kapi-imalat-malzemeleri' },
    ],
  },
  {
    title: 'Kurumsal',
    links: [
      { label: 'Hakkımızda', href: '/hakkimizda' },
      { label: 'Bayilik Belgeleri', href: '/hakkimizda/bayilik-belgeleri' },
      { label: 'İhracat', href: '/ihracat' },
      { label: 'Hizmet Bölgesi', href: '/hizmet-bolgesi' },
    ],
  },
  {
    title: 'İletişim',
    links: [
      { label: 'İletişim Bilgileri', href: '/iletisim' },
      { label: 'Teklif Al', href: '/iletisim/teklif-al' },
    ],
  },
];
---

<footer class="bg-primary text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">

      <!-- Şirket Bilgisi -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-4">
          <span class="text-white font-bold text-xl leading-none">
            Yiğiter
            <span class="block text-xs font-medium text-white/60 tracking-widest uppercase mt-0.5">
              Orman Ürünleri
            </span>
          </span>
        </a>
        <p class="text-white/70 text-sm leading-relaxed">
          20+ yıllık tecrübeyle orman ürünleri, mobilya malzemeleri ve kapı sanayiine hizmet veren yetkili bayi, üretici ve ihracatçı aile şirketi.
        </p>
        <div class="mt-5 flex flex-wrap gap-2">
          <span class="inline-block bg-white/10 text-white/70 text-xs px-2.5 py-1 rounded-full">
            Kastamonu Entegre Ana Bayisi
          </span>
          <span class="inline-block bg-white/10 text-white/70 text-xs px-2.5 py-1 rounded-full">
            Genç Boya Distribütörü
          </span>
          <span class="inline-block bg-white/10 text-white/70 text-xs px-2.5 py-1 rounded-full">
            Melamin İthalatçısı
          </span>
          <span class="inline-block bg-white/10 text-white/70 text-xs px-2.5 py-1 rounded-full">
            4 Kıtaya İhracat
          </span>
        </div>
      </div>

      <!-- Footer Linkleri -->
      {footerLinks.map((section) => (
        <div>
          <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">
            {section.title}
          </h3>
          <ul class="space-y-2.5">
            {section.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-white/70 hover:text-white text-sm transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- İletişim Bilgileri -->
    <div class="mt-10 pt-8 border-t border-white/20 grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        <div>
          <a href="tel:+902126702025" class="text-white/80 hover:text-white text-sm transition-colors block">0212 670 2025</a>
          <a href="tel:+905418187667" class="text-white/60 hover:text-white text-xs transition-colors block mt-0.5">0541 818 7667 (WhatsApp)</a>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        <div>
          <a href="mailto:dilek@yigiter.com.tr" class="text-white/80 hover:text-white text-sm transition-colors block">dilek@yigiter.com.tr</a>
          <a href="mailto:hilmi@yigiter.com.tr" class="text-white/60 hover:text-white text-xs transition-colors block mt-0.5">hilmi@yigiter.com.tr</a>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <p class="text-white/70 text-sm leading-relaxed">
          İkitelli Keresteciler Sitesi<br />
          Başakşehir / İstanbul
        </p>
      </div>
    </div>

    <!-- Alt Bar -->
    <div class="mt-8 pt-6 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-white/50 text-sm">
        © {currentYear} Yiğiter Orman Ürünleri. Tüm hakları saklıdır.
      </p>
      <p class="text-white/30 text-xs">
        yigiter.com.tr
      </p>
    </div>
  </div>
</footer>
