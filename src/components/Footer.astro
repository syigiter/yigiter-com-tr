---
const currentYear = new Date().getFullYear();

const footerLinks = [
  {
    title: 'Ürünler',
    links: [
      { label: 'Kastamonu Entegre', href: '/urunler/kastamonu-entegre' },
      { label: 'Genç Boya', href: '/urunler/genc-boya' },
      { label: 'Melamin Kapı Yüzeyleri', href: '/urunler/melamin-kapi-yuzeyi' },
      { label: 'Kapı Komponentleri', href: '/urunler/kapi-komponentleri' },
      { label: 'Kapı İmalat Malzemeleri', href: '/urunler/kapi-imalat-malzemeleri' },
    ],
  },
  {
    title: 'Kurumsal',
    links: [
      { label: 'Hakkımızda', href: '/hakkimizda' },
      { label: 'Yetkili Bayiliklerimiz', href: '/hakkimizda/bayilik-belgeleri' },
      { label: 'İhracat', href: '/ihracat' },
      { label: 'Hizmet Bölgesi', href: '/hizmet-bolgesi' },
      { label: 'KVKK ve Gizlilik Politikası', href: '/kvkk' },
    ],
  },
  {
    title: 'İletişim',
    links: [
      { label: 'Şubelerimiz', href: '/subeler' },
      { label: 'İletişim Bilgileri', href: '/iletisim' },
      { label: 'Teklif Al', href: '/teklif-al' },
    ],
  },
];
---

<footer class="bg-primary-900 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">

      <!-- Şirket Bilgisi -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-flex items-center gap-3 mb-4">
          <img src="/images/logo-amblem.png" alt="Yiğiter" class="h-10 w-auto" width="37" height="40" />
          <span class="text-white font-bold text-xl leading-none">
            Yiğiter
            <span class="block text-xs font-medium text-white/75 tracking-widest uppercase mt-0.5">
              Orman Ürünleri
            </span>
          </span>
        </a>
        <p class="text-white/70 text-sm leading-relaxed">
          20+ yıllık tecrübeyle orman ürünleri, mobilya malzemeleri ve kapı sanayiine hizmet veren yetkili bayi, üretici ve ihracatçı aile şirketi.
        </p>
        <div class="mt-5 flex flex-wrap gap-2">
          <span class="inline-block bg-white/10 text-white/70 text-xs px-2.5 py-1 rounded-full">
            Kastamonu Entegre Ana Bayisi
          </span>
          <span class="inline-block bg-white/10 text-white/70 text-xs px-2.5 py-1 rounded-full">
            Genç Boya Distribütörü ve Bayisi
          </span>
          <span class="inline-block bg-white/10 text-white/70 text-xs px-2.5 py-1 rounded-full">
            Melamin İthalatçısı
          </span>
          <span class="inline-block bg-white/10 text-white/70 text-xs px-2.5 py-1 rounded-full">
            4 Kıtaya İhracat
          </span>
        </div>
      </div>

      <!-- Footer Linkleri -->
      {footerLinks.map((section) => (
        <div>
          <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">
            {section.title}
          </h3>
          <ul class="space-y-2.5">
            {section.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-white/70 hover:text-white text-sm transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- İletişim Bilgileri -->
    <div class="mt-10 pt-8 border-t border-white/20 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        <div>
          <p class="text-white/70 text-xs mb-1">Kapı / Başakşehir</p>
          <a href="tel:+902126702025" class="text-white/80 hover:text-white text-sm transition-colors block">0212 670 2025</a>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        <div>
          <p class="text-white/70 text-xs mb-1">Boya / Ümraniye</p>
          <a href="tel:+905333876756" class="text-white/80 hover:text-white text-sm transition-colors block">0533 387 6756</a>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        <div>
          <p class="text-white/70 text-xs mb-1">Tosya Merkez</p>
          <a href="tel:+903663137667" class="text-white/80 hover:text-white text-sm transition-colors block">0366 313 7667</a>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        <div>
          <p class="text-white/70 text-xs mb-1">E-posta</p>
          <a href="mailto:info@yigiter.com.tr" class="text-white/80 hover:text-white text-sm transition-colors block">info@yigiter.com.tr</a>
        </div>
      </div>
    </div>

    <!-- Alt Bar -->
    <div class="mt-8 pt-6 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-white/70 text-sm">
        © {currentYear} Yiğiter Orman Ürünleri. Tüm hakları saklıdır.
      </p>
      <div class="flex items-center gap-4">
        <span class="text-white/70 text-xs">Pzt–Cum 08:30–18:00 · Cmt 08:30–15:00</span>
        <a
          href="https://wa.me/905415157667"
          target="_blank" rel="noopener noreferrer"
          class="flex items-center gap-1.5 bg-green-600 hover:bg-green-500 text-white text-xs font-semibold px-3 py-1.5 rounded-lg transition-colors"
        >
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp
        </a>
      </div>
    </div>
  </div>
</footer>
