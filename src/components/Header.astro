---
const navItems = [
  { label: 'Ana Sayfa', href: '/' },
  {
    label: 'Hakkımızda',
    href: '/hakkimizda/',
    children: [
      { label: 'Şirketimiz', href: '/hakkimizda/sirketimiz/' },
      { label: 'Yetkili Bayiliklerimiz', href: '/hakkimizda/bayilik-belgeleri/' },
      { label: 'İhracat', href: '/ihracat/' },
    ],
  },
  {
    label: 'Ürünler',
    href: '/urunler/',
    children: [
      { label: 'Kastamonu Entegre', href: '/urunler/kastamonu-entegre/' },
      { label: 'Genç Boya', href: '/urunler/genc-boya/' },
      { label: 'Melamin Kapı Yüzeyleri', href: '/urunler/melamin-kapi-yuzeyi/' },
      { label: 'Kapı Komponentleri', href: '/urunler/kapi-komponentleri/' },
      { label: 'Kapı İmalat Malzemeleri', href: '/urunler/kapi-imalat-malzemeleri/' },
    ],
  },
  { label: 'İhracat', href: '/ihracat/' },
  { label: 'Hizmet Bölgesi', href: '/hizmet-bolgesi/' },
  {
    label: 'İletişim',
    href: '/iletisim/',
    children: [
      { label: 'İletişim Bilgileri', href: '/iletisim/' },
      { label: 'Şubelerimiz', href: '/subeler/' },
      { label: 'Teklif Al', href: '/teklif-al/' },
    ],
  },
];
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">

      <!-- Logo -->
      <a href="/" class="flex items-center flex-shrink-0">
        <img
          src="/images/logo.png"
          alt="Yiğiter Orman Ürünleri"
          class="h-20 w-auto"
          width="160"
          height="80"
        />
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-1">
        {navItems.map((item, index) => (
          item.children ? (
            <div class="relative group">
              {item.label === 'Ürünler' ? (
                <div class="flex items-center rounded-md hover:bg-gray-50 transition-colors">
                  <a
                    href={item.href}
                    class="px-3 py-2 text-sm font-medium text-gray-700 hover:text-primary transition-colors"
                  >
                    {item.label}
                  </a>
                  <button
                    class="flex items-center px-1.5 py-2 text-gray-700 hover:text-primary transition-colors cursor-pointer"
                    type="button"
                    aria-label={`${item.label} alt menüsünü aç/kapat`}
                    aria-haspopup="true"
                    aria-expanded="false"
                    aria-controls={`desktop-dropdown-${index}`}
                    data-dropdown-button
                  >
                    <svg
                      class="w-3.5 h-3.5 text-gray-600 group-hover:rotate-180 transition-transform duration-200"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                    </svg>
                  </button>
                </div>
              ) : (
                <button
                  class="flex items-center gap-1 px-3 py-2 text-sm font-medium text-gray-700 hover:text-primary rounded-md hover:bg-gray-50 transition-colors cursor-pointer"
                  type="button"
                  aria-haspopup="true"
                  aria-expanded="false"
                  aria-controls={`desktop-dropdown-${index}`}
                  data-dropdown-button
                >
                  {item.label}
                  <svg
                    class="w-3.5 h-3.5 text-gray-600 group-hover:rotate-180 transition-transform duration-200"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                  </svg>
                </button>
              )}
              <div
                id={`desktop-dropdown-${index}`}
                class="absolute top-full left-0 w-56 bg-white border border-gray-200 rounded-lg shadow-lg py-1 opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-opacity duration-150 z-50"
                data-dropdown-menu
              >
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-primary transition-colors"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class="px-3 py-2 text-sm font-medium text-gray-700 hover:text-primary rounded-md hover:bg-gray-50 transition-colors"
            >
              {item.label}
            </a>
          )
        ))}
      </nav>

      <!-- CTA + Mobile Toggle -->
      <div class="flex items-center gap-3">
        <a
          href="/teklif-al/"
          class="hidden sm:inline-flex items-center gap-1.5 bg-accent hover:bg-accent-dark text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors"
        >
          Teklif Al
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
          </svg>
        </a>

        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 rounded-md text-gray-700 hover:bg-gray-100 transition-colors"
          aria-label="Menüyü aç/kapat"
          aria-expanded="false"
        >
          <svg id="hamburger-icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="close-icon" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-200 bg-white">
    <nav class="px-4 py-3 space-y-1 max-h-[80vh] overflow-y-auto">
      {navItems.map((item) => (
        item.children ? (
          <div class="pb-2">
            {item.label === 'Ürünler' ? (
              <a
                href={item.href}
                class="block px-3 py-1.5 text-xs font-semibold text-gray-600 uppercase tracking-wider hover:text-primary transition-colors"
              >
                {item.label}
              </a>
            ) : (
              <span class="block px-3 py-1.5 text-xs font-semibold text-gray-600 uppercase tracking-wider">
                {item.label}
              </span>
            )}
            {item.children.map((child) => (
              <a
                href={child.href}
                class="block px-4 py-2.5 text-sm text-gray-700 hover:text-primary hover:bg-gray-50 rounded-md transition-colors"
              >
                {child.label}
              </a>
            ))}
          </div>
        ) : (
          <a
            href={item.href}
            class="block px-3 py-2.5 text-sm font-medium text-gray-700 hover:text-primary hover:bg-gray-50 rounded-md transition-colors"
          >
            {item.label}
          </a>
        )
      ))}
      <div class="pt-3 pb-1 border-t border-gray-200">
        <a
          href="/teklif-al/"
          class="flex items-center justify-center gap-2 w-full bg-accent hover:bg-accent-dark text-white text-sm font-semibold px-4 py-3 rounded-lg transition-colors"
        >
          Teklif Al
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');
  const dropdownButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-dropdown-button]'));
  let pointerFocus = false;

  function getDropdown(button: HTMLButtonElement) {
    const menuId = button.getAttribute('aria-controls');
    return menuId ? document.getElementById(menuId) : null;
  }

  function getDropdownLinks(button: HTMLButtonElement) {
    return Array.from(getDropdown(button)?.querySelectorAll<HTMLAnchorElement>('a[href]') || []);
  }

  function focusFirstDropdownLink(button: HTMLButtonElement) {
    getDropdownLinks(button)[0]?.focus();
  }

  function closeDropdowns(except?: HTMLButtonElement) {
    dropdownButtons.forEach((button) => {
      if (button === except) return;
      const dropdown = getDropdown(button);
      button.setAttribute('aria-expanded', 'false');
      dropdown?.classList.remove('opacity-100', 'visible');
      dropdown?.classList.add('opacity-0', 'invisible');
      dropdown?.style.removeProperty('visibility');
    });
  }

  function openDropdown(button: HTMLButtonElement) {
    const dropdown = getDropdown(button);
    closeDropdowns(button);
    button.setAttribute('aria-expanded', 'true');
    dropdown?.classList.add('opacity-100', 'visible');
    dropdown?.classList.remove('opacity-0', 'invisible');
    dropdown?.style.setProperty('visibility', 'visible', 'important');
  }

  dropdownButtons.forEach((button) => {
    button.addEventListener('pointerdown', () => {
      pointerFocus = true;
      window.setTimeout(() => {
        pointerFocus = false;
      }, 0);
    });

    button.addEventListener('focus', () => {
      if (!pointerFocus) openDropdown(button);
    });

    button.addEventListener('click', (event) => {
      event.stopPropagation();
      const isOpen = button.getAttribute('aria-expanded') === 'true';
      if (isOpen) {
        closeDropdowns();
      } else {
        openDropdown(button);
      }
    });

    button.addEventListener('keydown', (event) => {
      if (['ArrowDown', 'Enter', ' '].includes(event.key)) {
        event.preventDefault();
        openDropdown(button);
        focusFirstDropdownLink(button);
      }

      if (event.key === 'Tab' && !event.shiftKey && button.getAttribute('aria-expanded') === 'true') {
        event.preventDefault();
        focusFirstDropdownLink(button);
      }
    });
  });

  document.addEventListener('focusin', (event) => {
    if (!(event.target instanceof Element)) return;
    if (!event.target.closest('[data-dropdown-button]') && !event.target.closest('[data-dropdown-menu]')) {
      closeDropdowns();
    }
  });

  document.addEventListener('click', (event) => {
    if (!(event.target instanceof Element)) return;
    if (!event.target.closest('[data-dropdown-button]') && !event.target.closest('[data-dropdown-menu]')) {
      closeDropdowns();
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeDropdowns();
      if (document.activeElement instanceof HTMLElement) {
        document.activeElement.blur();
      }
    }
  });

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden') === false;
    menu?.classList.toggle('hidden', isOpen);
    hamburger?.classList.toggle('hidden', !isOpen);
    closeIcon?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
