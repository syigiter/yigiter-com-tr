  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
    title: 'Boya ve Yüzey Çözümleri',
    description: 'Genç Boya distribütörlüğü ve bayiliğiyle mobilya imalatçıları, kapı üreticileri ve ahşap yüzey uygulamaları için boya ve yüzey çözümleri.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />`,
    title: 'Tosya OSB Altyapısı',
    description: 'Üretim, depolama ve sevkiyat süreçlerini Tosya OSB’deki altyapı avantajıyla yöneten kurumsal tedarik yapısı.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />`,
    title: 'Türkiye Geneli Sevkiyat',
    description: 'Bayiler, üreticiler, proje müşterileri ve toptan satış talepleri için düzenli sevkiyat ve teklif odaklı çalışma yaklaşımı.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 10h16M4 14h16M4 18h16" />`,
    title: 'İhracat Tecrübesi',
    description: 'Yurt içi pazarın yanında 4 kıtaya ihracat tecrübesiyle kapı komponentleri ve tedarik taleplerinde uluslararası beklentilere uyum.',
  },
];
---

<section class="bg-gray-50 py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Bölüm Başlığı -->
    <div class="text-center mb-12 lg:mb-16">
      <p class="text-accent-dark font-semibold text-sm uppercase tracking-widest mb-3">Neden Yiğiter?</p>
      <h2 class="text-3xl lg:text-4xl font-bold text-primary mb-4">
        Neden Yiğiter Orman Ürünleri?
      </h2>
      <p class="text-gray-700 text-base max-w-3xl mx-auto leading-relaxed">
        Kapı üreticileri, mobilya imalatçıları, bayiler ve proje bazlı alım yapan işletmeler için
        ürün çeşitliliği, güçlü tedarik altyapısı ve düzenli sevkiyat kabiliyetiyle güvenilir çözüm ortağı.
      </p>
    </div>

    <!-- Avantaj Kartları -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5 lg:gap-6">
      {advantages.map((adv) => (
        <div class="bg-white border border-gray-200 rounded-xl p-5 hover:border-primary/30 hover:shadow-sm transition-all duration-200">
          <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <Fragment set:html={adv.icon} />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 text-base mb-2">{adv.title}</h3>
          <p class="text-gray-700 text-sm leading-relaxed">{adv.description}</p>
        </div>
      ))}
    </div>

    <div class="mt-10 lg:mt-12 rounded-xl border border-primary/20 bg-white p-6 lg:p-8 text-center">
      <p class="text-gray-700 text-sm lg:text-base leading-relaxed max-w-3xl mx-auto mb-5">
        Ürün gruplarınız, ölçüleriniz ve adet bilgileriniz için teklif talebi oluşturabilirsiniz.
        MDF, MDFLAM, kapı kasası, kapı pervazı, melamin kapı yüzeyi, PVC film ve boya gruplarında
        proje bazlı tekliflerinizi değerlendirelim.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/teklif-al"
          class="inline-flex items-center justify-center gap-2 bg-[#9A3412] hover:bg-[#7C2D12] text-white font-bold px-6 py-3 rounded-lg text-sm transition-colors"
        >
          Teklif Al
        </a>
        <a
          href="/urunler/"
          class="inline-flex items-center justify-center gap-2 border border-primary text-primary hover:bg-primary hover:text-white font-semibold px-6 py-3 rounded-lg text-sm transition-colors"
        >
          Ürünleri İncele
        </a>
      </div>
    </div>
  </div>
</section>
