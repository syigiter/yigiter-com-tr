---

<section class="bg-white py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Bölüm Başlığı -->
    <div class="text-center mb-12 lg:mb-16">
      <p class="text-accent-dark font-semibold text-sm uppercase tracking-widest mb-3">Ürün ve Hizmetlerimiz</p>
      <h2 class="text-3xl lg:text-4xl font-bold text-primary mb-4">
        Tek Noktadan Eksiksiz Tedarik
      </h2>
      <p class="text-gray-700 text-base max-w-2xl mx-auto">
        Panel levhadan boyaya, kapı yüzeyinden kasa ve pervaza kadar kapı sanayiinin ihtiyaç duyduğu
        tüm malzemeleri tek çatı altında sunuyoruz.
      </p>
    </div>

    <!-- Ürün Kartları -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
      {products.map((product) => (
        <a
          href={product.href}
          class={`group relative flex flex-col bg-white border rounded-xl p-6 hover:shadow-lg transition-all duration-200 ${
            product.highlight
              ? 'border-accent/40 ring-1 ring-accent/20 hover:border-accent'
              : 'border-gray-200 hover:border-primary/40'
          }`}
        >
          {product.highlight && (
            <div class="absolute -top-3 left-6">
              <span class="bg-[#9A3412] text-white text-xs font-bold px-3 py-1 rounded-full">
                Kendi Üretimimiz
              </span>
            </div>
          )}

          <!-- Rol Rozeti + İkon -->
          <div class="flex items-start justify-between mb-4">
            <span class={`text-xs font-semibold px-2.5 py-1 rounded-full border ${product.badgeStyle}`}>
              {product.badge}
            </span>
            <div class={`w-9 h-9 flex-shrink-0 transition-colors ${product.highlight ? 'text-accent' : 'text-primary/60 group-hover:text-primary'}`}>
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" class="w-full h-full">
                <Fragment set:html={product.icon} />
              </svg>
            </div>
          </div>

          <!-- İçerik -->
          <h3 class="font-bold text-gray-900 text-base mb-1 group-hover:text-primary transition-colors">
            {product.title}
          </h3>
          <p class="text-gray-600 text-xs font-medium mb-3">{product.subtitle}</p>
          <p class="text-gray-700 text-sm leading-relaxed flex-grow">{product.description}</p>

          <!-- Link -->
          <div class={`mt-4 pt-4 border-t flex items-center gap-1.5 text-sm font-semibold transition-colors ${
            product.highlight
              ? 'border-accent/20 text-accent-dark'
              : 'border-gray-100 text-primary group-hover:text-accent-dark'
          }`}>
            İncele
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </a>
      ))}
    </div>

    <!-- Alt CTA -->
    <div class="text-center mt-10">
      <a
        href="/urunler/"
        class="inline-flex items-center gap-2 border border-primary text-primary hover:bg-primary hover:text-white font-semibold px-6 py-3 rounded-lg transition-colors text-sm"
      >
        Tüm Ürün Kategorilerini Gör
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>
