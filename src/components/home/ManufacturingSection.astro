---
const capabilities = [
  {
    title: 'Standart Ölçü Seri Üretim',
    description: 'Geniş stokumuzla kapı imalatçılarının acil ihtiyaçlarını beklemeden karşılıyoruz.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />`,
  },
  {
    title: 'Müşteriye Özel Üretim',
    description: 'Özel ölçü, profil ve proje gereksinimlerinde sipariş bazlı üretim yapıyoruz.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" />`,
  },
  {
    title: 'İhracat Kalitesinde Üretim',
    description: '4 farklı bölgeye sürekli ihracat yapmak üretim disiplini ve kalitesini uluslararası standartlarda tutuyor.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />`,
  },
  {
    title: 'Yurt İçi ve Uluslararası Sevkiyat',
    description: 'Türkiye genelinde ve dört kıtadaki ihracat pazarlarına kapı komponenti sevkiyatı yapıyoruz.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0" />`,
  },
];
---

<section class="bg-primary py-16 lg:py-24 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Sol: Görseller -->
      <div class="space-y-4">
        <figure class="relative rounded-xl overflow-hidden bg-white/5 border border-white/10 aspect-video shadow-lg">
          <img
            src="/images/yigiter-genel.jpg"
            alt="Yiğiter Orman Ürünleri üretim tesisi"
            class="w-full h-full object-cover"
            loading="lazy"
            width="1717"
            height="916"
          />
          <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-primary/85 to-transparent px-5 py-4">
            <figcaption class="text-white text-sm font-semibold">
              Yiğiter Orman Ürünleri üretim tesisi
            </figcaption>
          </div>
        </figure>
        <div class="grid grid-cols-2 gap-4">
          <figure class="relative rounded-xl overflow-hidden bg-white/5 border border-white/10 aspect-square">
            <img
              src="/images/yigiter-uretim-hatti.jpg"
              alt="Yiğiter Orman Ürünleri üretim hattı"
              class="w-full h-full object-cover"
              loading="lazy"
              width="1537"
              height="1023"
            />
            <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-primary/85 to-transparent px-4 py-3 text-white text-xs font-semibold">
              Üretim hattı
            </figcaption>
          </figure>
          <figure class="relative rounded-xl overflow-hidden bg-white/5 border border-white/10 aspect-square">
            <img
              src="/images/yigiter-fabrika-depo.jpg"
              alt="Yiğiter Orman Ürünleri stoktaki ürünleri"
              class="w-full h-full object-cover"
              loading="lazy"
              width="1535"
              height="1024"
            />
            <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-primary/85 to-transparent px-4 py-3 text-white text-xs font-semibold">
              Stok ve ürün alanı
            </figcaption>
          </figure>
        </div>
      </div>

      <!-- Sağ: İçerik -->
      <div>
        <span class="inline-block bg-accent/20 border border-accent/40 text-accent text-xs font-bold px-3 py-1.5 rounded-full uppercase tracking-wider mb-5">
          Kendi Üretimimiz
        </span>

        <h2 class="text-3xl lg:text-4xl font-bold text-white mb-5 leading-tight">
          Kapı Kasası ve Pervaz<br />
          Kendi Tesisimizde Üretilir
        </h2>

        <p class="text-white/70 text-base leading-relaxed mb-8">
          Yetkili bayiliklerimizin ötesinde, <strong class="text-white">kapı kasası ve pervazları kendi
          tesisimizde üretiyoruz.</strong> Dört farklı bölgeye düzenli ihracat yapmak, üretim kalitemizi
          uluslararası standartlarda tutma sorumluluğunu beraberinde getiriyor. Bu disiplin, yurt içi
          müşterilerimize de aynı kaliteyi sunmamızı sağlıyor.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
          {capabilities.map((cap) => (
            <div class="flex items-start gap-3">
              <div class="w-9 h-9 bg-accent/20 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <Fragment set:html={cap.icon} />
                </svg>
              </div>
              <div>
                <h4 class="text-white font-semibold text-sm mb-1">{cap.title}</h4>
                <p class="text-white/55 text-xs leading-relaxed">{cap.description}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href="/urunler/kapi-komponentleri"
            class="inline-flex items-center justify-center gap-2 bg-accent hover:bg-accent-dark text-white font-bold px-6 py-3 rounded-lg text-sm transition-colors"
          >
            Kapı Komponentlerini İncele
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
            </svg>
          </a>
          <a
            href="/teklif-al"
            class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white font-semibold px-6 py-3 rounded-lg text-sm transition-colors border border-white/20"
          >
            Teklif Al
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
