---
const roles = [
  {
    badge: 'Yetkili Ana Bayi',
    badgeColor: 'bg-blue-100 text-blue-700',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />`,
    title: 'Kastamonu Entegre Ana Bayisi',
    description:
      'Türkiye\'nin lider levha üreticisinin Ana Bayisi olarak yongalevha, MDF ve MDFLam ürünlerini stoktan sunuyoruz. Türkiye genelinde sevkiyat.',
    link: '/urunler/kastamonu-entegre',
  },
  {
    badge: 'Yetkili Distribütör',
    badgeColor: 'bg-green-100 text-green-700',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />`,
    title: 'Genç Boya Distribütörü ve Bayisi',
    description:
      'Genç Boya\'nın İstanbul Anadolu Yakası Distribütörü, Avrupa Yakası ve Tosya Bayisiyiz. Her iki yakada ve Karadeniz bölgesinde uzman boya şubelerimizle hızlı tedarik sağlıyoruz.',
    link: '/urunler/genc-boya',
  },
  {
    badge: 'Kendi Üretimimiz',
    badgeColor: 'bg-orange-100 text-orange-700',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />`,
    title: 'Kapı Kasası ve Pervaz Üreticisi',
    description:
      'Kapı kasası ve pervazlarını kendi tesisimizde üretiyoruz. Standart seri üretim ve müşteriye özel ölçü üretim kapasitemizle ihracat kalitesinde ürün sunuyoruz.',
    link: '/urunler/kapi-komponentleri',
  },
  {
    badge: '4 Kıtaya İhracat',
    badgeColor: 'bg-purple-100 text-purple-700',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
    title: 'Düzenli İhracatçı',
    description:
      'Ürettiğimiz kapı komponentlerini Avrupa, Orta Doğu, Türki Cumhuriyetler ve Afrika pazarlarına düzenli olarak ihraç ediyoruz.',
    link: '/ihracat',
  },
];
---

<section class="bg-white py-0 -mt-2 relative z-10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6 -translate-y-10 lg:-translate-y-14">
      {roles.map((role) => (
        <a
          href={role.link}
          class="group bg-white border border-gray-200 hover:border-primary rounded-xl p-5 lg:p-6 shadow-sm hover:shadow-md transition-all duration-200"
        >
          <!-- Badge -->
          <span class={`inline-block text-xs font-semibold px-2.5 py-1 rounded-full mb-4 ${role.badgeColor}`}>
            {role.badge}
          </span>

          <!-- Icon -->
          <div class="w-10 h-10 text-primary mb-3 group-hover:text-accent transition-colors">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" class="w-full h-full">
              <Fragment set:html={role.icon} />
            </svg>
          </div>

          <h3 class="font-bold text-gray-900 text-sm mb-2 group-hover:text-primary transition-colors leading-snug">
            {role.title}
          </h3>
          <p class="text-gray-500 text-xs leading-relaxed">
            {role.description}
          </p>
        </a>
      ))}
    </div>
  </div>
</section>
