---
const regions = [
  {
    name: 'Avrupa',
    icon: '🌍',
    description: 'Batı ve Doğu Avrupa ülkelerine düzenli kapı komponenti sevkiyatı.',
    color: 'bg-blue-50 border-blue-200 text-blue-800',
    iconBg: 'bg-blue-100',
  },
  {
    name: 'Orta Doğu',
    icon: '🌐',
    description: 'Irak, Suriye, Körfez ülkeleri ve çevre bölgelere düzenli sevkiyat.',
    color: 'bg-amber-50 border-amber-200 text-amber-800',
    iconBg: 'bg-amber-100',
  },
  {
    name: 'Türki Cumhuriyetler',
    icon: '🗺️',
    description: 'Orta Asya ve Türki Cumhuriyetlere köklü ticari ilişkilerle ihracat.',
    color: 'bg-purple-50 border-purple-200 text-purple-800',
    iconBg: 'bg-purple-100',
  },
  {
    name: 'Afrika',
    icon: '🌍',
    description: 'Afrika pazarına kapı ve orman ürünleri komponentleri sevkiyatı.',
    color: 'bg-green-50 border-green-200 text-green-800',
    iconBg: 'bg-green-100',
  },
];
---

<section class="bg-wood py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Sol: İçerik -->
      <div>
        <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-3">İhracat</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-primary mb-5 leading-tight">
          Dört Kıtaya<br />Düzenli Sevkiyat
        </h2>

        <p class="text-gray-600 text-base leading-relaxed mb-6">
          Kendi tesisimizde ürettiğimiz kapı kasası ve pervazları, Türkiye'nin ötesine
          taşıyarak <strong class="text-gray-800">Avrupa, Orta Doğu, Türki Cumhuriyetler ve Afrika</strong>
          pazarlarına düzenli olarak ihraç ediyoruz.
        </p>

        <p class="text-gray-600 text-base leading-relaxed mb-8">
          Dört farklı bölgeye sürekli ihracat, üretimimizin uluslararası standartlara uygun kalmasını zorunlu kılıyor.
          Bu disiplin, yurt içi müşterilerimize de aynı ihracat kalitesinde ürün sunmamızı sağlıyor.
        </p>

        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href="/ihracat"
            class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-light text-white font-bold px-6 py-3 rounded-lg text-sm transition-colors"
          >
            İhracat Bilgileri
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
            </svg>
          </a>
          <a
            href="/iletisim/teklif-al"
            class="inline-flex items-center justify-center gap-2 border border-primary text-primary hover:bg-primary hover:text-white font-semibold px-6 py-3 rounded-lg text-sm transition-colors"
          >
            İhracat Talebi
          </a>
        </div>
      </div>

      <!-- Sağ: Bölge Kartları -->
      <div>
        <!-- İhracat Haritası (TIM 2025 verileri) -->
        <div class="bg-white border border-gray-200 rounded-xl p-3 mb-5 overflow-hidden">
          <img
            src="/images/ihracat-haritasi.png"
            alt="Yiğiter Orman Ürünleri — 2025 yılı ihracat ülkeleri haritası"
            class="w-full h-auto rounded-lg"
            loading="lazy"
            width="1512"
            height="796"
          />
          <p class="text-center text-xs text-gray-400 mt-2">Kaynak: TIM — Türkiye İhracatçılar Meclisi, 2025</p>
        </div>

        <div class="grid grid-cols-2 gap-3">
          {regions.map((region) => (
            <div class={`border rounded-xl p-4 ${region.color}`}>
              <div class={`w-8 h-8 ${region.iconBg} rounded-lg flex items-center justify-center text-lg mb-2`}>
                {region.icon}
              </div>
              <h4 class="font-bold text-sm mb-1">{region.name}</h4>
              <p class="text-xs opacity-80 leading-snug">{region.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
