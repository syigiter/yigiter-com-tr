---
const stats = [
  { value: '20+', label: 'Yıllık Tecrübe' },
  { value: '4', label: 'Kıtaya İhracat' },
  { value: '3', label: 'Bölgesel Depo' },
  { value: 'TR Geneli', label: 'Sevkiyat Ağı' },
];
---

<section class="bg-gray-50 py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Sol: Şirket Tanımı -->
      <div>
        <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-3">Biz Kimiz</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-primary mb-6 leading-tight">
          20+ Yıllık Tecrübe,<br />Uluslararası Üretici Aile Şirketi
        </h2>

        <p class="text-gray-600 text-base leading-relaxed mb-5">
          Yiğiter Orman Ürünleri, 20 yılı aşkın süredir Türkiye'nin orman ürünleri, mobilya malzemeleri ve
          kapı sanayii sektörlerine hizmet veren köklü bir aile şirketidir. Kurucumuzun aktif yönetiminde
          faaliyetini sürdüren firmamız; <strong class="text-gray-800">yetkili bayilik ve distribütörlükleri</strong>,
          <strong class="text-gray-800">kendi üretimi kapı komponentleri</strong> ve
          <strong class="text-gray-800">dört kıtaya uzanan ihracat ağı</strong> ile sektörün geniş bir yelpazesine
          çözüm sunmaktadır.
        </p>

        <div class="space-y-3 mb-8">
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-600 text-sm">
              <strong class="text-gray-800">Kastamonu Entegre Ana Bayisi</strong> — Yongalevha, MDF, MDFLam; Türkiye geneli sevkiyat
            </span>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-600 text-sm">
              <strong class="text-gray-800">Genç Boya Distribütörü ve Bayisi</strong> — Anadolu Yakası Distribütör, Avrupa Yakası ve Tosya Bayi
            </span>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-600 text-sm">
              <strong class="text-gray-800">Kapı kasası ve pervaz üreticisi</strong> — Standart seri + müşteriye özel üretim
            </span>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-600 text-sm">
              <strong class="text-gray-800">Melamin kaplı kapı yüzeyi ithalatçısı</strong> — Yurt dışından özenle seçilmiş kaliteli ürünler
            </span>
          </div>
        </div>

        <a
          href="/hakkimizda/sirketimiz"
          class="inline-flex items-center gap-2 text-primary hover:text-accent font-semibold text-sm transition-colors group"
        >
          Şirket Hikayemizi Okuyun
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

      <!-- Sağ: Stats + Görsel Placeholder -->
      <div class="space-y-6">
        <!-- Stats grid -->
        <div class="grid grid-cols-2 gap-4">
          {stats.map((stat) => (
            <div class="bg-white border border-gray-200 rounded-xl p-5 text-center shadow-sm">
              <div class="text-3xl font-extrabold text-primary mb-1">{stat.value}</div>
              <div class="text-gray-500 text-xs font-medium uppercase tracking-wide">{stat.label}</div>
            </div>
          ))}
        </div>

        <figure class="relative rounded-xl overflow-hidden bg-primary/10 border border-primary/20 aspect-video shadow-sm">
          <img
            src="/images/yigiter-sirket-resmi.jpg"
            alt="Yiğiter Orman Ürünleri şirket binası"
            class="w-full h-full object-cover"
            loading="lazy"
            width="1586"
            height="992"
          />
          <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-primary/80 to-transparent px-5 py-4">
            <figcaption class="text-white text-sm font-semibold">
              Yiğiter Orman Ürünleri şirket binası
            </figcaption>
          </div>
        </figure>
      </div>
    </div>
  </div>
</section>
