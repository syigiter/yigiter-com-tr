---
---
<section
  class="relative overflow-hidden flex items-center"
  style="min-height: 88vh; background: linear-gradient(135deg, #0f2035 0%, #1e3a5f 55%, #264d78 100%);"
>
  <!-- Subtle diagonal grid pattern -->
  <div
    class="absolute inset-0 opacity-[0.04]"
    style="background-image: repeating-linear-gradient(45deg, #fff 0, #fff 1px, transparent 0, transparent 50%); background-size: 32px 32px;"
  ></div>

  <!-- Right-side decorative shape -->
  <div class="absolute right-0 top-0 bottom-0 w-1/2 opacity-10 hidden lg:block overflow-hidden">
    <div
      class="absolute right-[-10%] top-[-10%] w-[120%] h-[120%] rounded-[40%_0_0_40%]"
      style="background: radial-gradient(ellipse at center, #fff 0%, transparent 70%);"
    ></div>
  </div>

  <div class="relative w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
    <div class="max-w-3xl">

      <!-- Top badges -->
      <div class="flex flex-wrap gap-2 mb-8">
        <span class="inline-flex items-center bg-white/10 border border-white/20 text-white/85 rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-wider">
          20+ Yıllık Aile Şirketi
        </span>
        <span class="inline-flex items-center bg-accent/20 border border-accent/40 text-accent rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-wider">
          4 Kıtaya Düzenli İhracat
        </span>
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-[1.1] mb-6">
        Orman Ürünleri ve<br />
        Kapı Sanayiinde<br />
        <span class="text-accent">Güvenilir Tedarikçiniz</span>
      </h1>

      <p class="text-white/70 text-lg sm:text-xl leading-relaxed mb-8 max-w-2xl">
        Mobilya imalatçılarına, kapı üreticilerine ve bölgesel bayilere
        geniş ürün yelpazesiyle Türkiye geneli ve 4 kıtaya hizmet veriyoruz.
      </p>

      <!-- Role pills -->
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1.5 mb-10">
        <span class="text-white/50 text-sm">Kastamonu Entegre Ana Bayisi</span>
        <span class="text-white/25 hidden sm:inline">·</span>
        <span class="text-white/50 text-sm">Genç Boya Distribütörü</span>
        <span class="text-white/25 hidden sm:inline">·</span>
        <span class="text-white/50 text-sm">Kapı Kasası Üreticisi</span>
        <span class="text-white/25 hidden sm:inline">·</span>
        <span class="text-white/50 text-sm">Melamin İthalatçısı</span>
      </div>

      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="/iletisim/teklif-al"
          class="inline-flex items-center justify-center gap-2 bg-accent hover:bg-accent-dark text-white font-bold px-8 py-4 rounded-lg text-base transition-colors shadow-lg"
        >
          Teklif Al
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
          </svg>
        </a>
        <a
          href="/urunler"
          class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white font-semibold px-8 py-4 rounded-lg text-base transition-colors border border-white/25"
        >
          Ürünlerimizi İncele
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom wave -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg
      viewBox="0 0 1440 56"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      class="w-full block"
      preserveAspectRatio="none"
    >
      <path
        d="M0 56L1440 56L1440 20C1080 50 720 0 360 30C240 40 120 50 0 30L0 56Z"
        fill="white"
      />
    </svg>
  </div>
</section>
