---
---
<section class="bg-primary py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-10 lg:mb-12">
      <h2 class="text-3xl lg:text-4xl font-bold text-white mb-4 leading-tight">
        Fiyat Teklifi veya Bilgi İçin<br />
        <span class="text-orange-300">Hemen İletişime Geçin</span>
      </h2>
      <p class="text-white/85 text-base max-w-2xl mx-auto">
        Küçük atölyenin tek paketlik siparişini de fabrikanın TIR'lık sevkiyatını da aynı özenle ele alıyoruz.
        Doğru ürünü, doğru zamanda, doğru fiyata ulaştırmak için buradayız.
      </p>
    </div>

    <!-- CTA Butonları -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center max-w-2xl mx-auto">

      <!-- Birincil: Teklif Al -->
      <a
        href="/teklif-al"
        class="w-full sm:w-auto flex items-center justify-center gap-3 bg-[#9A3412] hover:bg-[#7C2D12] text-white font-bold px-8 py-4 rounded-xl text-base transition-colors shadow-lg min-w-[200px]"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        Fiyat Teklifi Al
      </a>

      <!-- İkincil: WhatsApp (bölüm seçimli) -->
      <button
        id="wa-btn"
        type="button"
        class="w-full sm:w-auto flex items-center justify-center gap-3 bg-green-700 hover:bg-green-800 text-white font-bold px-8 py-4 rounded-xl text-base transition-colors shadow-lg min-w-[200px]"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        WhatsApp ile Yaz
      </button>

      <!-- Üçüncül: Telefon -->
      <a
        href="tel:+902126702025"
        class="w-full sm:w-auto flex items-center justify-center gap-3 bg-white/10 hover:bg-white/20 text-white font-semibold px-8 py-4 rounded-xl text-base transition-colors border border-white/25 min-w-[200px]"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Bizi Arayın
      </a>
    </div>

    <!-- Alt bilgi -->
    <p class="text-center text-white/85 text-xs mt-8">
      Hafta içi her gün hizmetinizdeyiz — 0212 670 2025
    </p>
  </div>
</section>

<!-- WhatsApp Bölüm Seçim Modalı -->
<div id="wa-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4">
  <!-- Overlay -->
  <div id="wa-overlay" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>

  <!-- Modal -->
  <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-md p-6">
    <div class="flex items-center justify-between mb-5">
      <div>
        <h3 class="text-lg font-bold text-gray-900">WhatsApp ile Ulaşın</h3>
        <p class="text-gray-700 text-sm mt-0.5">Hangi bölümle görüşmek istersiniz?</p>
      </div>
      <button id="wa-close" aria-label="WhatsApp penceresini kapat" class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-gray-100 text-gray-600 hover:text-gray-800 transition-colors">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <div class="space-y-2">
      {[
        { bolum: 'Kapı Ürünleri', aciklama: 'Kasa, pervaz, melamin yüzey, kağıt dolgu, PVC film', tel: '905415157667' },
        { bolum: 'MDF & Panel Satış', aciklama: 'Kastamonu Entegre — yongalevha, MDF, MDFLam', tel: '905464886737' },
        { bolum: 'Genç Boya — Avrupa Yakası', aciklama: 'Boya, vernik, astar, sertleştirici', tel: '905417602735' },
        { bolum: 'Genç Boya — Anadolu Yakası', aciklama: 'Boya, vernik, astar, sertleştirici', tel: '905333876756' },
        { bolum: 'Tosya Merkez Satış', aciklama: 'Genel ürün satışı, Tosya ve çevresi', tel: '905319313310' },
      ].map((item) => (
        <a
          href={`https://wa.me/${item.tel}?text=Merhaba%2C%20Yi%C4%9Fiter%20Orman%20%C3%9Cr%C3%BCnleri%27ne%20ula%C5%9Fmak%20istiyorum.`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 p-3 rounded-xl border border-gray-200 hover:border-green-600/60 hover:bg-green-50 transition-all group"
        >
          <div class="w-9 h-9 bg-green-100 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:bg-green-200 transition-colors">
            <svg class="w-4 h-4 text-green-700" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <div class="min-w-0">
            <p class="font-semibold text-gray-900 text-sm">{item.bolum}</p>
            <p class="text-gray-600 text-xs truncate">{item.aciklama}</p>
          </div>
          <svg class="w-4 h-4 text-gray-500 group-hover:text-green-700 flex-shrink-0 ml-auto transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      ))}
    </div>
  </div>
</div>

<script>
  const btn = document.getElementById('wa-btn');
  const modal = document.getElementById('wa-modal');
  const overlay = document.getElementById('wa-overlay');
  const closeBtn = document.getElementById('wa-close');

  function openModal() {
    modal!.classList.remove('hidden');
    modal!.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal!.classList.add('hidden');
    modal!.classList.remove('flex');
    document.body.style.overflow = '';
  }

  btn?.addEventListener('click', openModal);
  overlay?.addEventListener('click', closeModal);
  closeBtn?.addEventListener('click', closeModal);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>
