---
const depots = [
  {
    name: 'Anadolu Yakası Deposu',
    region: 'İstanbul, Anadolu Yakası',
    products: 'Kastamonu Entegre, Genç Boya, Melamin Yüzey, Kapı Komponentleri',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />`,
    highlight: true,
  },
  {
    name: 'Avrupa Yakası Deposu',
    region: 'İstanbul, Avrupa Yakası',
    products: 'Genç Boya — Bölgesel hızlı tedarik',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />`,
    highlight: false,
  },
  {
    name: 'Tosya Bayisi',
    region: 'Kastamonu, Tosya',
    products: 'Genç Boya — Karadeniz bölgesi hizmet noktası',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />`,
    highlight: false,
  },
  {
    name: 'Üretim Tesisi',
    region: 'TODO: Konum eklenecek',
    products: 'Kapı kasası ve pervaz üretimi',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />`,
    highlight: false,
  },
];
---

<section class="bg-white py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Bölüm Başlığı -->
    <div class="text-center mb-12 lg:mb-16">
      <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-3">Hizmet Bölgesi</p>
      <h2 class="text-3xl lg:text-4xl font-bold text-primary mb-4">
        Türkiye Geneline Hizmet
      </h2>
      <p class="text-gray-500 text-base max-w-2xl mx-auto">
        İstanbul'daki depolarımız ve Tosya bayimizle Türkiye'nin geniş bir coğrafyasına hizmet veriyoruz.
        Sevkiyat ağımızla siparişlerinizi Türkiye geneline ulaştırıyoruz.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-14 items-start">

      <!-- Sol: Türkiye Haritası Placeholder -->
      <div>
        <div class="bg-gray-50 border border-gray-200 rounded-xl overflow-hidden aspect-[4/3] flex items-center justify-center">
          <!-- TODO: Türkiye haritası SVG eklenecek (depo lokasyonları işaretli) -->
          <div class="text-center px-6">
            <svg class="w-16 h-16 text-primary/20 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
            </svg>
            <p class="text-gray-400 text-sm font-medium">Türkiye hizmet haritası</p>
            <p class="text-gray-300 text-xs mt-1">Depo lokasyonları işaretlenecek</p>
          </div>
        </div>

        <!-- Türkiye geneli vurgu -->
        <div class="mt-4 bg-primary/5 border border-primary/15 rounded-xl p-4 flex items-center gap-4">
          <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0" />
            </svg>
          </div>
          <div>
            <p class="text-primary font-semibold text-sm">Türkiye Geneline Sevkiyat</p>
            <p class="text-gray-500 text-xs">Kastamonu Entegre ürünlerinde Türkiye'nin her yerine sevkiyat imkânı.</p>
          </div>
        </div>
      </div>

      <!-- Sağ: Depo & Lokasyon Listesi -->
      <div class="space-y-4">
        {depots.map((depot) => (
          <div class={`border rounded-xl p-4 lg:p-5 ${depot.highlight ? 'border-primary/30 bg-primary/5' : 'border-gray-200 bg-white'}`}>
            <div class="flex items-start gap-4">
              <div class={`w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 ${depot.highlight ? 'bg-primary text-white' : 'bg-gray-100 text-gray-500'}`}>
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <Fragment set:html={depot.icon} />
                </svg>
              </div>
              <div>
                <h4 class={`font-bold text-sm mb-0.5 ${depot.highlight ? 'text-primary' : 'text-gray-800'}`}>
                  {depot.name}
                </h4>
                <p class="text-gray-500 text-xs mb-1.5">{depot.region}</p>
                <p class="text-gray-400 text-xs leading-relaxed">{depot.products}</p>
              </div>
            </div>
          </div>
        ))}

        <a
          href="/hizmet-bolgesi"
          class="flex items-center justify-center gap-2 border border-primary text-primary hover:bg-primary hover:text-white font-semibold px-5 py-3 rounded-xl text-sm transition-colors mt-2"
        >
          Hizmet Bölgesi Detayları
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
