---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Aradığınız sayfa bulunamadı"
  description="Aradığınız sayfa bulunamadı. Yiğiter Orman Ürünleri ana sayfasına, ürünlere veya teklif formuna dönebilirsiniz."
>
  <section class="bg-gray-50 py-16 lg:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-3">404</p>
      <h1 class="text-4xl lg:text-5xl font-bold text-primary mb-5">Aradığınız sayfa bulunamadı</h1>
      <p class="text-gray-600 text-lg leading-relaxed mb-8">
        Sayfa taşınmış veya adres hatalı yazılmış olabilir. Aşağıdaki bağlantılarla devam edebilirsiniz.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-3">
        <a href="/" class="inline-flex items-center justify-center rounded-lg bg-primary px-6 py-3 font-semibold text-white hover:bg-primary-light transition-colors">Ana Sayfaya Dön</a>
        <a href="/urunler" class="inline-flex items-center justify-center rounded-lg border border-primary px-6 py-3 font-semibold text-primary hover:bg-primary hover:text-white transition-colors">Ürünleri Gör</a>
        <a href="/teklif-al" class="inline-flex items-center justify-center rounded-lg bg-accent px-6 py-3 font-semibold text-white hover:bg-accent-dark transition-colors">Teklif Al</a>
      </div>
      <div class="mt-8 text-sm text-gray-500">
        <a href="tel:+902126702025" class="hover:text-primary">+90 212 670 20 25</a>
        <span class="mx-2 text-gray-300">|</span>
        <a href="https://wa.me/905319313310" class="hover:text-primary">WhatsApp ile yazın</a>
      </div>
    </div>
  </section>
</BaseLayout>
