---
import BaseLayout from '../layouts/BaseLayout.astro';

const sections = [
  {
    title: 'Veri sorumlusu',
    body: [
      'Kişisel verileriniz, veri sorumlusu sıfatıyla Yiğiter Orman Ürünleri Ltd. Şti. tarafından işlenebilir.',
      'Başvuru ve iletişim için web sitemizde yer alan iletişim kanallarını kullanabilirsiniz.',
    ],
  },
  {
    title: 'Hangi kişisel veriler işlenir?',
    body: [
      'Web sitemizdeki teklif ve iletişim formları üzerinden ad soyad, firma adı, telefon numarası, e-posta adresi, şehir, teslimat yeri, talep edilen ürün veya hizmet bilgisi, ölçü, adet, metraj, proje bilgileri ve mesaj alanında tarafınızca paylaşılan bilgiler alınabilir.',
      'Web sitesinin güvenliği ve çalışması kapsamında teknik olarak IP adresi, tarayıcı bilgisi, cihaz bilgisi, ziyaret zamanı ve benzeri teknik veriler de işlenebilir.',
    ],
  },
  {
    title: 'Kişisel veriler hangi amaçlarla işlenir?',
    items: [
      'Teklif taleplerinin alınması, değerlendirilmesi ve yanıtlanması',
      'Ürün ve hizmetlerimiz hakkında bilgi verilmesi',
      'Müşteri taleplerinin ve iletişim kayıtlarının yönetilmesi',
      'Satış, sevkiyat, tedarik ve müşteri ilişkileri süreçlerinin yürütülmesi',
      'Yasal yükümlülüklerin yerine getirilmesi',
      'Web sitesinin güvenliğinin, performansının ve teknik işleyişinin sağlanması',
    ],
  },
  {
    title: 'Kişisel veriler hangi yollarla toplanır?',
    body: [
      'Kişisel verileriniz; web sitemizdeki formlar, e-posta, telefon, WhatsApp ve diğer iletişim kanalları üzerinden elektronik ya da fiziki yollarla toplanabilir.',
      'Form gönderimleri, teknik hizmet sağlayıcı altyapıları üzerinden tarafımıza iletilebilir.',
    ],
  },
  {
    title: 'Kişisel veriler kimlerle paylaşılabilir?',
    body: [
      'Kişisel verileriniz, talebinize yanıt verilmesi ve hizmet süreçlerinin yürütülmesi için gerekli olduğu ölçüde şirket içindeki ilgili birimler, teknik hizmet sağlayıcılar, kargo ve lojistik hizmet sağlayıcıları, mali ve hukuki danışmanlar ile yetkili kamu kurumlarıyla paylaşılabilir.',
      'Paylaşım, yalnızca talebin niteliği, hizmetin yürütülmesi veya yasal zorunluluklar kapsamında gerekli olduğu ölçüde yapılır.',
    ],
  },
  {
    title: 'Saklama süresi',
    body: [
      'Kişisel verileriniz, işleme amacının gerektirdiği süre boyunca ve ilgili mevzuatta öngörülen yasal saklama süreleri kapsamında saklanır.',
      'Saklama süresi sona erdiğinde kişisel veriler silinir, yok edilir veya anonim hale getirilir.',
    ],
  },
  {
    title: 'İlgili kişinin hakları',
    body: [
      'KVKK kapsamında kişisel verilerinizle ilgili olarak bilgi talep etme, işlenip işlenmediğini öğrenme, işlenmişse buna ilişkin bilgi isteme, düzeltilmesini isteme, silinmesini veya yok edilmesini isteme, işleme amacına uygun kullanılıp kullanılmadığını öğrenme ve mevzuatta yer alan diğer haklarınızı kullanabilirsiniz.',
    ],
  },
  {
    title: 'Başvuru ve iletişim',
    body: [
      'KVKK kapsamındaki başvurularınızı iletişim sayfamızda yer alan kanallar üzerinden Yiğiter Orman Ürünleri’ne iletebilirsiniz.',
      'Genel iletişim: info@yigiter.com.tr · 0212 670 2025',
      'Adres: İkitelli Keresteciler Sitesi, Ziyagökalp Mah., 23. Sokak, 24. Blok No:38/40, Başakşehir / İstanbul',
    ],
  },
  {
    title: 'Çerezler ve teknik veriler',
    body: [
      'Web sitemizin çalışması, güvenliği ve performansının ölçülmesi amacıyla teknik çerezler ve benzeri teknolojiler kullanılabilir.',
      'Bu veriler site deneyimini iyileştirmek, teknik sorunları analiz etmek ve güvenliği sağlamak amacıyla işlenebilir.',
    ],
  },
];
---

<BaseLayout
  title="KVKK ve Gizlilik Politikası"
  description="Yiğiter Orman Ürünleri web sitesi üzerinden iletilen teklif, iletişim ve müşteri talepleri kapsamında kişisel verilerin işlenmesine ilişkin bilgilendirme metni."
>
  <section class="bg-gray-50 border-b border-gray-200 py-12 lg:py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-accent-dark font-semibold text-sm uppercase tracking-widest mb-3">Yasal Bilgilendirme</p>
      <h1 class="text-4xl lg:text-5xl font-bold text-primary mb-5 leading-tight">
        KVKK ve Gizlilik Politikası
      </h1>
      <p class="text-gray-700 text-lg leading-relaxed max-w-3xl">
        Yiğiter Orman Ürünleri olarak, web sitemiz üzerinden bizimle iletişime geçen ziyaretçilerimizin
        ve müşterilerimizin kişisel verilerinin gizliliğine önem veriyoruz. Bu metin,
        www.yigiter.com.tr üzerinden iletilen teklif, iletişim ve benzeri talepler kapsamında kişisel
        verilerin hangi amaçlarla işlendiğini açıklamak amacıyla hazırlanmıştır.
      </p>
    </div>
  </section>

  <section class="py-12 lg:py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[220px_1fr] gap-8 lg:gap-12">
        <aside class="lg:sticky lg:top-24 self-start">
          <nav class="border border-gray-200 rounded-lg p-4 bg-white">
            <h2 class="text-sm font-bold text-primary mb-3">İçindekiler</h2>
            <ul class="space-y-2">
              {sections.map((section) => (
                <li>
                  <a href={`#${section.title.toLowerCase().replaceAll(' ', '-')}`} class="text-sm text-gray-700 hover:text-primary transition-colors">
                    {section.title}
                  </a>
                </li>
              ))}
              <li>
                <a href="#guncelleme-tarihi" class="text-sm text-gray-700 hover:text-primary transition-colors">
                  Güncelleme tarihi
                </a>
              </li>
            </ul>
          </nav>
        </aside>

        <div class="space-y-8">
          {sections.map((section) => (
            <section id={section.title.toLowerCase().replaceAll(' ', '-')} class="border-b border-gray-200 pb-8 scroll-mt-28">
              <h2 class="text-2xl font-bold text-primary mb-4">{section.title}</h2>
              {section.body && (
                <div class="space-y-3">
                  {section.body.map((paragraph) => (
                    <p class="text-gray-700 leading-relaxed">{paragraph}</p>
                  ))}
                </div>
              )}
              {section.items && (
                <ul class="space-y-2">
                  {section.items.map((item) => (
                    <li class="flex gap-2 text-gray-700 leading-relaxed">
                      <span class="mt-2 h-1.5 w-1.5 rounded-full bg-accent-dark shrink-0" aria-hidden="true"></span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              )}
            </section>
          ))}

          <section id="guncelleme-tarihi" class="scroll-mt-28">
            <h2 class="text-2xl font-bold text-primary mb-4">Güncelleme tarihi</h2>
            <p class="text-gray-700 leading-relaxed">
              Bu metin ihtiyaç halinde güncellenebilir. Güncel metin www.yigiter.com.tr/kvkk adresinde yayımlanır.
            </p>
            <p class="mt-3 text-sm text-gray-700">
              Son güncelleme: 25 Haziran 2026
            </p>
          </section>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
