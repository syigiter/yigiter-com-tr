---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="İletişim"
  description="Yiğiter Orman Ürünleri — İletişim bilgileri, adresler, telefon, e-posta. Hızlı iletişim için teklif formu."
>
  <!-- Hero -->
  <section class="bg-gray-50 py-12 lg:py-16 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-2">İletişim</p>
        <h1 class="text-4xl lg:text-5xl font-bold text-primary mb-4 leading-tight">
          Bize Ulaşın
        </h1>
        <p class="text-gray-600 text-lg">
          Sorularınız, teklifleriniz ve tavsiyeleriniz için aşağıdaki iletişim kanallarını kullanabilirsiniz.
        </p>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-10 mb-16">

        <!-- Sol: İletişim Bilgileri -->
        <div class="lg:col-span-2">
          <h2 class="text-3xl font-bold text-primary mb-8">İletişim Bilgileri</h2>

          <!-- Telefon -->
          <div class="mb-8">
            <h3 class="text-lg font-bold text-gray-900 mb-3 flex items-center gap-2">
              <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              Telefon
            </h3>
            <div class="space-y-3 ml-7">
              <div>
                <p class="text-gray-500 text-xs uppercase tracking-wide mb-1">Sabit Telefon (İkitelli)</p>
                <a href="tel:+902126702025" class="text-gray-900 font-semibold hover:text-accent transition-colors">0212 670 2025</a>
              </div>
              <div>
                <p class="text-gray-500 text-xs uppercase tracking-wide mb-1">Cep / WhatsApp</p>
                <a href="tel:+905418187667" class="text-gray-900 font-semibold hover:text-accent transition-colors">0541 818 7667</a>
              </div>
            </div>
          </div>

          <!-- E-posta -->
          <div class="mb-8">
            <h3 class="text-lg font-bold text-gray-900 mb-3 flex items-center gap-2">
              <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              E-posta
            </h3>
            <div class="space-y-3 ml-7">
              <div>
                <p class="text-gray-500 text-xs uppercase tracking-wide mb-1">Genel İletişim</p>
                <a href="mailto:dilek@yigiter.com.tr" class="text-gray-900 font-semibold hover:text-accent transition-colors">dilek@yigiter.com.tr</a>
              </div>
              <div>
                <p class="text-gray-500 text-xs uppercase tracking-wide mb-1">İhracat / Yönetim</p>
                <a href="mailto:hilmi@yigiter.com.tr" class="text-gray-900 font-semibold hover:text-accent transition-colors">hilmi@yigiter.com.tr</a>
              </div>
            </div>
          </div>

          <!-- Adresler -->
          <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Adresler
          </h3>

          <div class="space-y-4 ml-7">
            <div class="border border-gray-200 rounded-lg p-4">
              <h4 class="font-bold text-gray-900 text-sm mb-1">Üretim Tesisi</h4>
              <p class="text-gray-600 text-sm leading-relaxed mb-2">
                Karasapaca Köyü Kurtbeli OSB Mevkii 3. Cad. No:2 İç Kapı:1
              </p>
              <a href="tel:+905418187667" class="text-accent text-sm font-medium">0541 818 7667</a>
            </div>

            <div class="border border-gray-200 rounded-lg p-4">
              <h4 class="font-bold text-gray-900 text-sm mb-1">Anadolu Yakası — Boya Satış (İstanbul)</h4>
              <p class="text-gray-600 text-sm leading-relaxed mb-2">
                Necip Fazıl Bulvarı Keyap Sanayi Sitesi No:44/133 H Blok, Ümraniye / İstanbul
              </p>
              <div class="flex gap-3">
                <a href="tel:+905337876756" class="text-accent text-sm font-medium">0533 387 6756</a>
                <span class="text-gray-300">|</span>
                <a href="tel:+905417177667" class="text-accent text-sm font-medium">0541 717 7667</a>
              </div>
            </div>

            <div class="border border-gray-200 rounded-lg p-4">
              <h4 class="font-bold text-gray-900 text-sm mb-1">Avrupa Yakası — Kapı Ürünleri (İstanbul)</h4>
              <p class="text-gray-600 text-sm leading-relaxed mb-2">
                İkitelli Keresteciler Sitesi Ziyagökalp Mah. 23. Sokak 24. Blok No:38/40, Başakşehir / İstanbul
              </p>
              <div class="flex gap-3">
                <a href="tel:+902126702025" class="text-accent text-sm font-medium">0212 670 2025</a>
                <span class="text-gray-300">|</span>
                <a href="tel:+905415157667" class="text-accent text-sm font-medium">0541 515 7667</a>
              </div>
            </div>

            <div class="border border-gray-200 rounded-lg p-4">
              <h4 class="font-bold text-gray-900 text-sm mb-1">Tosya Bayisi (Kastamonu)</h4>
              <p class="text-gray-600 text-sm leading-relaxed mb-2">
                Harsat Mahallesi 8. Yukarı Sanayi Sokak, Tosya / Kastamonu
              </p>
              <div class="flex gap-3">
                <a href="tel:+903663137667" class="text-accent text-sm font-medium">0366 313 7667</a>
                <span class="text-gray-300">|</span>
                <a href="tel:+905319313310" class="text-accent text-sm font-medium">0531 931 3310</a>
              </div>
            </div>
          </div>

          <!-- Çalışma Saatleri -->
          <div class="mt-8 p-4 bg-primary/5 border border-primary/20 rounded-lg">
            <h4 class="font-bold text-primary text-sm mb-2">Çalışma Saatleri</h4>
            <!-- TODO: Çalışma saatleri eklenecek -->
            <p class="text-gray-400 italic text-sm">Çalışma saatleri eklenecek</p>
          </div>
        </div>

        <!-- Sağ: Harita ve CTA -->
        <div class="space-y-6">

          <!-- Harita Placeholder -->
          <div class="rounded-xl overflow-hidden border border-gray-200 bg-gray-50 aspect-square flex items-center justify-center">
            <!-- TODO: Google Maps embed veya interaktif harita eklenecek -->
            <div class="text-center px-4">
              <svg class="w-12 h-12 text-gray-300 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <p class="text-gray-400 text-sm">Harita eklenecek</p>
            </div>
          </div>

          <!-- Hızlı İletişim CTA -->
          <div class="bg-primary text-white rounded-xl p-6">
            <h3 class="font-bold text-lg mb-4">Hızlı İletişim</h3>

            <a
              href="/iletisim/teklif-al"
              class="flex items-center justify-center gap-2 bg-accent hover:bg-accent-dark text-white font-bold px-4 py-3 rounded-lg transition-colors text-sm mb-3 w-full"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Teklif Al
            </a>

            <a
              href="https://wa.me/905418187667"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 bg-[#25D366] hover:bg-[#1da851] text-white font-semibold px-4 py-3 rounded-lg transition-colors text-sm mb-3 w-full"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              0541 818 7667
            </a>

            <a
              href="tel:+902126702025"
              class="flex items-center justify-center gap-2 bg-white/20 hover:bg-white/30 text-white font-semibold px-4 py-3 rounded-lg transition-colors text-sm w-full"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              0212 670 2025
            </a>
          </div>

        </div>
      </div>

    </div>
  </section>

</BaseLayout>
