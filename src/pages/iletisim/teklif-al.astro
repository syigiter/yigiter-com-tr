---
const target = '/teklif-al';
---

<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, follow" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={`https://yigiter.com.tr${target}`} />
    <title>Teklif Al | Yiğiter Orman Ürünleri</title>
    <script is:inline>
      window.location.replace('/teklif-al' + window.location.search);
    </script>
  </head>
  <body>
    <p>Teklif formuna yönlendiriliyorsunuz. <a href={target}>Devam etmek için tıklayın.</a></p>
  </body>
</html>
