---
import BaseLayout from '../../layouts/BaseLayout.astro';

const relatedProducts = [
  {
    title: 'Kapı Komponentleri',
    href: '/urunler/kapi-komponentleri/',
    description: 'Kapı kasası, kapı pervazı, kapı paneli ve yüzey malzemelerini kapsayan ana kategori.',
  },
  {
    title: 'Kapı Kasası',
    href: '/teklif-al?urun=kapi-kasasi',
    description: 'Kapı pervazı ile birlikte değerlendirilebilecek kasa çözümleri.',
  },
  {
    title: 'Melamin Kapı Yüzeyi',
    href: '/teklif-al?urun=melamin-kapi-yuzeyi',
    description: 'Kapı üretimi ve yüzey uygulamalarını birlikte planlayan alımlar için.',
  },
];

const createProfileImages = (slug: string, total: number) =>
  Array.from(
    { length: total },
    (_, index) => `/images/products/pervaz/pervaz-${slug}-profil-${String(index + 1).padStart(2, '0')}.webp`,
  );

const pervazProfileGroups = [
  {
    title: 'Bombeli Pervaz',
    images: createProfileImages('bombeli', 2),
  },
  {
    title: 'PVC Dekoratif Pervaz',
    images: createProfileImages('pvc-dekoratif', 4),
  },
  {
    title: 'Ham Dekoratif Pervaz',
    images: createProfileImages('ham-dekoratif', 3),
  },
  {
    title: 'Dekoratif Pervaz',
    images: createProfileImages('dekoratif', 1),
  },
  {
    title: 'Hareli Pervaz',
    images: createProfileImages('hareli', 4),
  },
  {
    title: 'Hareli Kanallı Pervaz',
    images: createProfileImages('hareli-kanalli', 4),
  },
  {
    title: 'Lakelik Ham Pervaz',
    images: createProfileImages('lakelik-ham', 11),
  },
  {
    title: 'Taç Pervaz',
    images: createProfileImages('tac', 4),
  },
];
---

<BaseLayout
  title="Kapı Pervazı Tedariki"
  description="Kapı pervazı nedir, hangi ölçü ve model seçenekleri vardır? Kapı üreticileri, bayiler ve projeler için toptan kapı pervazı tedariki ve teklif alın."
>
  <section class="bg-wood-100 border-b border-wood-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
      <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,2fr)_minmax(280px,1fr)] gap-8 lg:gap-10 items-start">
        <div class="max-w-3xl">
          <p class="text-accent-dark font-semibold text-sm uppercase tracking-widest mb-3">B2B Ürün Detayı</p>
          <h1 class="text-4xl lg:text-5xl font-bold text-primary mb-4 leading-tight">Kapı Pervazı</h1>
          <p class="text-gray-700 text-lg leading-relaxed">
            Kapı üreticileri, bayiler ve proje müşterileri için seri üretim, toptan alım ve proje bazlı
            kapı pervazı tedarik çözümleri. Kapı kasası ve pervaz birlikte değerlendirildiğinde,
            iç kapı üretimi ve montaj süreçlerinde tutarlı bir bitiş ve estetik bütünlük sağlar.
          </p>

          <div class="mt-6 flex flex-col sm:flex-row gap-3">
            <a
              href="/teklif-al?urun=kapi-pervazi"
              class="inline-flex items-center justify-center rounded-lg bg-[#9A3412] px-6 py-3 text-sm font-bold text-white hover:bg-[#7C2D12] transition-colors"
            >
              Teklif Al
            </a>
            <a
              href="/urunler/"
              class="inline-flex items-center justify-center rounded-lg border border-primary px-6 py-3 text-sm font-semibold text-primary hover:bg-primary hover:text-white transition-colors"
            >
              Tüm Ürünleri İncele
            </a>
          </div>
        </div>

        <aside class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
          <h2 class="text-lg font-bold text-primary mb-4">Kısa Tedarik Notu</h2>
          <ul class="space-y-3 text-sm text-gray-700">
            <li>Kapı yan sanayi için uygun, toptan kapı pervazı tedarik yaklaşımı.</li>
            <li>Tosya OSB üretim ve tedarik altyapısı ile planlanmış sevkiyat.</li>
            <li>Türkiye geneli sevkiyat ve proje bazlı teklif desteği.</li>
            <li>Kapı kasası ve pervaz, kapı komponentleri ve yüzey malzemeleriyle birlikte planlanabilir.</li>
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <section class="py-12 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,2fr)_minmax(280px,1fr)] gap-8 lg:gap-10 items-start">
        <div class="space-y-6">
          <section class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
            <h2 class="text-2xl font-bold text-primary mb-3">Kapı Pervazı Nedir?</h2>
            <p class="text-gray-700 leading-relaxed">
              Kapı pervazı, kapı montajında kasa-duvar birleşimini tamamlayan ve geçişi estetik olarak
              bitiren yan elemandır. İç kapı üretiminde, renovasyon işlerinde ve kapı montaj
              uygulamalarında düzenli görünüm ve tamamlayıcı çözüm sağlar. Yiğiter olarak kapı pervazı
              tedarikini kapı üreticileri, bayiler ve proje bazlı alımlar için B2B mantıkla ele alıyoruz.
            </p>
          </section>

          <section class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
            <h2 class="text-2xl font-bold text-primary mb-4">Kimler İçin Uygundur?</h2>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {[
                'Kapı üreticileri',
                'Bayiler ve toptancılar',
                'Proje bazlı kapı tedarikçileri',
                'Mobilya ve dekorasyon atölyeleri',
                'Montaj ekipleri',
              ].map((item) => (
                <li class="flex items-start gap-2 rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-700">
                  <span class="mt-2 h-1.5 w-1.5 rounded-full bg-accent-dark shrink-0" aria-hidden="true"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </section>

          <section class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
            <h2 class="text-2xl font-bold text-primary mb-4">Kullanım Alanları</h2>
            <ul class="space-y-3 text-sm text-gray-700">
              {[
                'İç kapı üretimi',
                'Kapı montaj ve renovasyon işleri',
                'Konut projeleri',
                'Otel, ofis, okul ve toplu yapı projeleri',
                'Bayi ve toptan satış kanalları',
              ].map((item) => (
                <li class="flex items-start gap-2">
                  <span class="mt-2 h-1.5 w-1.5 rounded-full bg-primary shrink-0" aria-hidden="true"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </section>

          <section class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
            <h2 class="text-2xl font-bold text-primary mb-4">Teklif İçin Hangi Bilgiler Gerekir?</h2>
            <ul class="space-y-3 text-sm text-gray-700">
              {[
                'Profil / model tercihi',
                'Renk veya yüzey tercihi',
                'Tahmini metre / takım miktarı',
                'Teslimat ili',
                'Proje veya bayi alımı bilgisi',
                'Termin beklentisi',
              ].map((item) => (
                <li class="flex items-start gap-2">
                  <span class="mt-2 h-1.5 w-1.5 rounded-full bg-accent-dark shrink-0" aria-hidden="true"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <div class="mt-5">
              <a
                href="/teklif-al?urun=kapi-pervazi"
                class="inline-flex items-center justify-center rounded-lg bg-[#9A3412] px-5 py-3 text-sm font-bold text-white hover:bg-[#7C2D12] transition-colors"
              >
                Kapı Pervazı İçin Teklif Al
              </a>
            </div>
          </section>

          <section class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
            <h2 class="text-2xl font-bold text-primary mb-4">Yiğiter ile Tedarik Avantajı</h2>
            <ul class="space-y-3 text-sm text-gray-700">
              {[
                'Tosya OSB üretim ve tedarik altyapısı',
                'Kapı yan sanayi tecrübesi',
                'Türkiye geneli sevkiyat',
                'Toptan ve proje bazlı teklif yaklaşımı',
                'Kapı kasası, kapı komponentleri ve yüzey malzemeleriyle birlikte tedarik imkânı',
              ].map((item) => (
                <li class="flex items-start gap-2">
                  <span class="mt-2 h-1.5 w-1.5 rounded-full bg-primary shrink-0" aria-hidden="true"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <p class="mt-5 text-gray-700 leading-relaxed">
              Kapı pervazı tedarikçisi arayan kapı üreticileri için, düzenli sevkiyat ve proje bazlı
              teklif süreçleriyle hareket ediyoruz. Seri üretim, bayi alımı ve iç kapı üretimi
              ihtiyaçlarında tek noktadan çözüm sunmayı hedefliyoruz.
            </p>
          </section>
        </div>

        <aside class="space-y-6 lg:sticky lg:top-6">
          <section class="rounded-xl border border-gray-200 bg-gray-50 p-6">
            <h2 class="text-lg font-bold text-primary mb-3">İlgili Ürünler</h2>
            <div class="space-y-3">
              {relatedProducts.map((product) => (
                <a href={product.href} class="block rounded-lg border border-gray-200 bg-white p-4 hover:border-primary/40 hover:shadow-sm transition-all">
                  <h3 class="font-bold text-gray-900 text-sm mb-1">{product.title}</h3>
                  <p class="text-gray-600 text-xs leading-relaxed">{product.description}</p>
                </a>
              ))}
            </div>
            <a
              href="/urunler/"
              class="mt-4 inline-flex items-center justify-center rounded-lg border border-primary px-4 py-2.5 text-sm font-semibold text-primary hover:bg-primary hover:text-white transition-colors"
            >
              Tüm Ürünler
            </a>
          </section>

          <section class="rounded-xl border border-primary/20 bg-primary p-6 text-white shadow-sm">
            <h2 class="text-xl font-bold mb-3">Proje Bazlı Teklif İçin Hazırız</h2>
            <p class="text-white/85 text-sm leading-relaxed mb-5">
              Kapı pervazı, kapı kasası ve kapı komponentleri aynı talep içinde toplanabilir. Ölçü,
              profil, metraj ve teslimat bilgilerini paylaşmanız yeterli.
            </p>
            <a
              href="/teklif-al?urun=kapi-pervazi"
              class="inline-flex items-center justify-center rounded-lg bg-[#9A3412] px-5 py-3 text-sm font-bold text-white hover:bg-[#7C2D12] transition-colors"
            >
              Teklif Al
            </a>
          </section>
        </aside>
      </div>
    </div>
  </section>

  <section class="border-t border-gray-200 bg-gray-50 py-12 lg:py-20" aria-labelledby="pervaz-profil-ornekleri">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-accent-dark font-semibold text-sm uppercase tracking-widest mb-3">Profil Aileleri</p>
        <h2 id="pervaz-profil-ornekleri" class="text-3xl lg:text-4xl font-bold text-primary mb-4">
          Pervaz Profil Örnekleri
        </h2>
        <p class="text-gray-700 leading-relaxed">
          Aşağıdaki görseller, üretim geçmişimizde yer alan pervaz profil ailelerinden örnekleri
          göstermektedir. Güncel profil, yüzey, ölçü, stok ve termin bilgileri teklif aşamasında
          netleştirilir.
        </p>
      </div>

      <div class="mt-10 space-y-12">
        {pervazProfileGroups.map((group, groupIndex) => {
          const headingId = `pervaz-profil-grubu-${groupIndex + 1}`;

          return (
            <section aria-labelledby={headingId}>
              <div class="mb-5 flex items-center gap-4">
                <h3 id={headingId} class="shrink-0 text-xl font-bold text-gray-900">{group.title}</h3>
                <span class="h-px w-full bg-gray-300" aria-hidden="true"></span>
              </div>

              <div class="grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-4 lg:gap-6">
                {group.images.map((src) => (
                  <figure class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
                    <img
                      src={src}
                      alt={`${group.title} profil örneği`}
                      width="640"
                      height="640"
                      loading="lazy"
                      decoding="async"
                      class="aspect-square w-full object-cover"
                    />
                    <figcaption class="border-t border-gray-100 px-3 py-3 text-sm font-medium text-gray-700">
                      {group.title}
                    </figcaption>
                  </figure>
                ))}
              </div>
            </section>
          );
        })}
      </div>

      <div class="mt-12 rounded-xl border border-amber-200 bg-amber-50 p-5 sm:flex sm:items-center sm:justify-between sm:gap-6">
        <p class="text-sm leading-relaxed text-amber-950">
          Bu görseller stok listesi veya kesin teknik katalog değildir. Aktif profil, yüzey ve ölçü
          kombinasyonları sipariş detayına göre teklif aşamasında doğrulanır.
        </p>
        <a
          href="/teklif-al?urun=kapi-pervazi"
          class="mt-4 inline-flex shrink-0 items-center justify-center rounded-lg bg-[#9A3412] px-5 py-3 text-sm font-bold text-white transition-colors hover:bg-[#7C2D12] sm:mt-0"
        >
          Pervaz için teklif alın
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
