---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Kapı İmalat Malzemeleri"
  description="Yiğiter Orman Ürünleri — Kapı imalatçıları için kağıt dolgu (honeycomb), PVC film ve yardımcı malzemeler. Tek noktadan tedarik, stoktan hızlı teslimat."
>
  <!-- Breadcrumb -->
  <nav class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ol class="flex items-center gap-2 text-sm text-gray-500">
        <li><a href="/" class="hover:text-primary transition-colors">Anasayfa</a></li>
        <li class="text-gray-300">/</li>
        <li><a href="/urunler" class="hover:text-primary transition-colors">Ürünler</a></li>
        <li class="text-gray-300">/</li>
        <li class="text-gray-800 font-medium">Kapı İmalat Malzemeleri</li>
      </ol>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="bg-wood-100 py-12 lg:py-16 border-b border-wood-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-2 bg-orange-50 text-orange-700 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-widest mb-4">
          Tek Noktadan Tedarik
        </span>
        <h1 class="text-4xl lg:text-5xl font-bold text-primary mb-4 leading-tight">
          Kapı İmalat Malzemeleri
        </h1>
        <p class="text-gray-600 text-lg leading-relaxed">
          Kapı üreticilerinin ihtiyaç duyduğu yardımcı malzemeleri stoktan, hızla tedarik ediyoruz.
          Üretim hattınız durmadan çalışsın.
        </p>
      </div>
    </div>
  </section>

  <!-- Ana İçerik -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-16">

        <!-- Sol: Metin -->
        <div class="lg:col-span-2">

          <!-- Alt Kategoriler -->
          <h2 class="text-2xl font-bold text-primary mb-6">Ürün Kategorileri</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-12">

            <a href="/urunler/kapi-imalat-malzemeleri/kagit-dolgu" class="group border border-gray-200 rounded-xl p-5 hover:border-primary/40 hover:shadow-sm transition-all">
              <div class="flex items-start justify-between mb-3">
                <h3 class="font-bold text-gray-900 group-hover:text-primary transition-colors">
                  Kağıt Dolgu Malzemesi
                </h3>
                <svg class="w-4 h-4 text-gray-300 group-hover:text-primary transition-colors shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                </svg>
              </div>
              <p class="text-gray-500 text-sm">
                Honeycomb / petek dolgu. İç kapı imalatında ağırlığı düşürürken yapısal sağlamlık sağlar.
              </p>
              <p class="text-accent text-xs font-semibold mt-3">Stoktan Teslimat →</p>
            </a>

            <a href="/urunler/kapi-imalat-malzemeleri/pvc-film" class="group border border-gray-200 rounded-xl p-5 hover:border-primary/40 hover:shadow-sm transition-all">
              <div class="flex items-start justify-between mb-3">
                <h3 class="font-bold text-gray-900 group-hover:text-primary transition-colors">
                  PVC Film
                </h3>
                <svg class="w-4 h-4 text-gray-300 group-hover:text-primary transition-colors shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                </svg>
              </div>
              <p class="text-gray-500 text-sm">
                Kapı ve mobilya yüzey kaplaması için geniş desen ve renk yelpazesinde PVC film.
              </p>
              <p class="text-accent text-xs font-semibold mt-3">Stoktan Teslimat →</p>
            </a>

          </div>

          <!-- Neden Tek Noktadan -->
          <h2 class="text-2xl font-bold text-primary mb-5">Tek Noktadan Eksiksiz Tedarik</h2>
          <p class="text-gray-700 text-base leading-relaxed mb-6">
            Kapı üreticileri olarak ihtiyaç duyduğunuz malzemeleri tek bir tedarikçiden karşılayarak
            lojistiği basitleştiriyoruz. Levhadan boyaya, dolgudan PVC filme kadar ihtiyacınız olan
            her şey Yiğiter'den.
          </p>
          <ul class="space-y-3 mb-10">
            {[
              'Geniş stok — üretim hattınız beklemez',
              'Kapı sanayine özel tedarik tecrübesi',
              'Diğer kapı malzemeleriyle birlikte tek noktadan tedarik',
              'Rekabetçi toptan fiyat',
              'Esnek sipariş miktarları',
            ].map((item) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700 text-sm">{item}</span>
              </li>
            ))}
          </ul>

          <!-- Tam Tedarik Ekosistemi -->
          <div class="bg-wood rounded-2xl p-6">
            <h3 class="text-primary font-bold mb-3">Kapı İmalatı İçin Tam Tedarik Ekosistemi</h3>
            <p class="text-primary/70 text-sm leading-relaxed mb-4">
              Yiğiter Orman Ürünleri olarak kapı imalatçısının ihtiyaç duyduğu
              tüm bileşenleri tek çatı altında sunuyoruz:
            </p>
            <div class="grid grid-cols-2 gap-2">
              {[
                { label: 'Panel / Levha', href: '/urunler/kastamonu-entegre' },
                { label: 'Kapı Yüzeyi', href: '/urunler/melamin-kapi-yuzeyi' },
                { label: 'Kasa & Pervaz', href: '/urunler/kapi-komponentleri' },
                { label: 'Boya & Vernik', href: '/urunler/genc-boya' },
                { label: 'Kağıt Dolgu', href: '/urunler/kapi-imalat-malzemeleri/kagit-dolgu' },
                { label: 'PVC Film', href: '/urunler/kapi-imalat-malzemeleri/pvc-film' },
              ].map((item) => (
                <a href={item.href} class="flex items-center gap-2 text-primary hover:text-accent transition-colors text-sm font-medium">
                  <span class="w-1.5 h-1.5 bg-accent rounded-full shrink-0"></span>
                  {item.label}
                </a>
              ))}
            </div>
          </div>

        </div>

        <!-- Sağ: CTA -->
        <div class="space-y-5">
          <div class="bg-primary rounded-2xl p-6 text-white">
            <h3 class="text-lg font-bold mb-2">Fiyat Teklifi Alın</h3>
            <p class="text-white/70 text-sm mb-4">
              İhtiyaçlarınızı bildirin, toptan fiyatla teklif hazırlayalım.
            </p>
            <a
              href="/iletisim/teklif-al?urun=Kap%C4%B1+%C4%B0malat+Malzemeleri"
              class="block text-center bg-accent hover:bg-accent-dark text-white font-bold px-5 py-3 rounded-lg transition-colors"
            >
              Teklif Al
            </a>
          </div>

          <div class="bg-green-50 border border-green-200 rounded-2xl p-6">
            <h3 class="text-green-800 font-bold mb-3 text-sm">WhatsApp ile İletişim</h3>
            <a
              href="https://wa.me/905418187667" target="_blank" rel="noopener noreferrer"
              class="block text-center bg-green-600 hover:bg-green-700 text-white font-bold px-5 py-3 rounded-lg transition-colors text-sm"
            >
              WhatsApp
            </a>
          </div>

          <div class="border border-gray-200 rounded-2xl p-5">
            <h3 class="font-bold text-gray-900 mb-4 text-sm">Tüm Ürünler</h3>
            <a href="/urunler" class="text-primary hover:text-accent text-sm font-medium transition-colors flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
              </svg>
              Ürün Kataloğu
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
