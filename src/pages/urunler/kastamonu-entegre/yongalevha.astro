---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Yongalevha (Sunta)"
  description="Kastamonu Entegre yongalevha (sunta) — Yiğiter Orman Ürünleri Ana Bayi. Mobilya ve genel imalat için geniş stok, Türkiye geneli sevkiyat."
>
  <!-- Breadcrumb -->
  <nav class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ol class="flex items-center gap-2 text-sm text-gray-500">
        <li><a href="/" class="hover:text-primary transition-colors">Anasayfa</a></li>
        <li class="text-gray-300">/</li>
        <li><a href="/urunler" class="hover:text-primary transition-colors">Ürünler</a></li>
        <li class="text-gray-300">/</li>
        <li><a href="/urunler/kastamonu-entegre" class="hover:text-primary transition-colors">Kastamonu Entegre</a></li>
        <li class="text-gray-300">/</li>
        <li class="text-gray-800 font-medium">Yongalevha</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="bg-gray-50 py-12 lg:py-16 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-2 bg-accent/10 text-accent text-xs font-bold px-3 py-1 rounded-full uppercase tracking-widest mb-4">
          Kastamonu Entegre — Ana Bayi
        </span>
        <h1 class="text-4xl lg:text-5xl font-bold text-primary mb-4 leading-tight">
          Yongalevha (Sunta)
        </h1>
        <p class="text-gray-600 text-lg">
          Mobilya ve genel imalatın temel panel çözümü. Kastamonu Entegre Ana Bayisi sıfatıyla
          geniş stok ve rekabetçi fiyatla sunuyoruz.
        </p>
      </div>
    </div>
  </section>

  <!-- İçerik -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-16">

        <div class="lg:col-span-2">

          <!-- TODO: Ürün görseli eklenecek -->
          <div class="bg-gray-100 rounded-2xl aspect-video flex items-center justify-center mb-8 text-gray-400 text-sm">
            Yongalevha ürün görseli eklenecek
          </div>

          <p class="text-gray-700 text-base leading-relaxed mb-5">
            Yongalevha (sunta), mobilya imalatından genel yapı uygulamalarına kadar geniş bir
            kullanım alanına sahip temel panel ürünüdür. Kastamonu Entegre'nin Ana Bayisi olarak
            tüm yongalevha portföyünü stoktan sunuyoruz.
          </p>

          <p class="text-gray-700 text-base leading-relaxed mb-10">
            Geniş ölçü, renk ve desen seçenekleriyle her imalat projesine uygun yongalevha çeşidini
            bulabilirsiniz. Türkiye geneli sevkiyat ağımızla siparişiniz en kısa sürede size ulaşır.
          </p>

          <!-- Ürün Özellikleri -->
          <h2 class="text-xl font-bold text-primary mb-5">Ürün Özellikleri</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
            {[
              { label: 'Marka', value: 'Kastamonu Entegre' },
              { label: 'Bayi Statüsü', value: 'Ana Bayi' },
              { label: 'Sevkiyat', value: 'Türkiye Geneli' },
              { label: 'Teslimat', value: 'Stoktan' },
              { label: 'Ölçüler', value: '2800×2070 mm (standart levha); özel kesim mevcut' },
              { label: 'Yüzey', value: 'Ham (çıplak), melamin kaplı seçenekler' },
            ].map((spec) => (
              <div class="flex justify-between py-3 border-b border-gray-100">
                <span class="text-gray-500 text-sm">{spec.label}</span>
                <span class="text-gray-900 text-sm font-medium" set:html={spec.value} />
              </div>
            ))}
          </div>

          <!-- Kullanım Alanları -->
          <h2 class="text-xl font-bold text-primary mb-4">Kullanım Alanları</h2>
          <ul class="space-y-2 mb-10">
            {[
              'Mobilya imalatı (dolap, masa, sandalye gövdesi)',
              'Mutfak ve banyo mobilyası',
              'Kapı kanatı ve kasa dolgu',
              'İç dekorasyon kaplama uygulamaları',
              'Raf ve modüler ürünler',
            ].map((item) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700 text-sm">{item}</span>
              </li>
            ))}
          </ul>

        </div>

        <!-- Sağ: CTA -->
        <div class="space-y-5">
          <div class="bg-primary rounded-2xl p-6 text-white">
            <h3 class="text-lg font-bold mb-2">Fiyat Teklifi Alın</h3>
            <p class="text-white/70 text-sm mb-4">
              Yongalevha için ihtiyacınızı bildirin, teklif hazırlayalım.
            </p>
            <a
              href="/iletisim/teklif-al?urun=Yongalevha+%28Kastamonu+Entegre%29"
              class="block text-center bg-accent hover:bg-accent-dark text-white font-bold px-5 py-3 rounded-lg transition-colors"
            >
              Teklif Al
            </a>
          </div>

          <div class="bg-green-50 border border-green-200 rounded-2xl p-6">
            <h3 class="text-green-800 font-bold mb-3 text-sm">WhatsApp ile İletişim</h3>
            <a
              href="https://wa.me/905418187667" target="_blank" rel="noopener noreferrer"
              class="block text-center bg-green-600 hover:bg-green-700 text-white font-bold px-5 py-3 rounded-lg transition-colors text-sm"
            >
              WhatsApp
            </a>
          </div>

          <div class="bg-wood rounded-2xl p-5">
            <p class="text-primary/80 text-xs leading-relaxed">
              Kastamonu Entegre Ana Bayisi olarak orijinal ürün ve üretici garantisi.
            </p>
          </div>

          <!-- İlgili Ürünler -->
          <div class="border border-gray-200 rounded-2xl p-5">
            <h3 class="font-bold text-gray-900 mb-4 text-sm">İlgili Ürünler</h3>
            <ul class="space-y-3">
              <li>
                <a href="/urunler/kastamonu-entegre/mdf" class="text-primary hover:text-accent text-sm font-medium transition-colors flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                  </svg>
                  MDF
                </a>
              </li>
              <li>
                <a href="/urunler/kastamonu-entegre/mdflam" class="text-primary hover:text-accent text-sm font-medium transition-colors flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                  </svg>
                  MDFLam
                </a>
              </li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
