---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Kastamonu Entegre Kapı Paneli"
  description="Kastamonu Entegre kapı paneli ürünleri — Yiğiter Orman Ürünleri Ana Bayi güvencesiyle. Melamin ve laminat yüzeyli kapı paneli, stoktan teslimat."
>
  <!-- Breadcrumb -->
  <nav class="bg-gray-50 border-b border-gray-200 py-3">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ol class="flex items-center gap-2 text-sm text-gray-500">
        <li><a href="/" class="hover:text-primary transition-colors">Anasayfa</a></li>
        <li class="text-gray-300">/</li>
        <li><a href="/urunler" class="hover:text-primary transition-colors">Ürünler</a></li>
        <li class="text-gray-300">/</li>
        <li><a href="/urunler/kastamonu-entegre" class="hover:text-primary transition-colors">Kastamonu Entegre</a></li>
        <li class="text-gray-300">/</li>
        <li class="text-gray-800 font-medium">Kapı Paneli</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="bg-wood-100 py-12 lg:py-16 border-b border-wood-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-2 bg-accent/10 text-accent text-xs font-bold px-3 py-1 rounded-full uppercase tracking-widest mb-4">
          Kastamonu Entegre — Ana Bayi
        </span>
        <h1 class="text-4xl lg:text-5xl font-bold text-primary mb-3 leading-tight">
          Kapı Paneli
        </h1>
        <p class="text-accent font-semibold text-base mb-4">Kapı Üreticileri İçin Hazır Panel Çözümleri</p>
        <p class="text-gray-600 text-lg leading-relaxed">
          Kastamonu Entegre'nin kapı üretimine özel melamin ve laminat yüzeyli panel seçeneklerini
          Ana Bayi güvencesiyle, stoktan sunuyoruz.
        </p>
      </div>
    </div>
  </section>

  <!-- Ana İçerik -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-16">

        <!-- Sol: Metin -->
        <div class="lg:col-span-2">
          <p class="text-gray-700 text-base leading-relaxed mb-5">
            <strong class="text-gray-900">Kastamonu Entegre Kapı Paneli</strong>, kapı gövdesi, çerçeve ve
            dekor yüzeylerinde kullanılmak üzere özel olarak geliştirilen, yüksek baskı dayanımına sahip
            panel ürünleridir.
          </p>
          <p class="text-gray-700 text-base leading-relaxed mb-10">
            Melamin ve laminat yüzey seçenekleriyle geniş bir renk ve desen kataloğuna sahip olan kapı paneli
            serisi; hem seri üretim hem de özel proje bazlı kapı imalatçılarının ihtiyaçlarına yanıt vermektedir.
            <strong class="text-gray-900">Yiğiter Orman Ürünleri</strong> olarak bu ürünleri Ana Bayi statüsüyle,
            üretici garantisiyle sunuyoruz.
          </p>

          <!-- Özellikler -->
          <h2 class="text-2xl font-bold text-primary mb-6">Ürün Özellikleri</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
            {[
              { baslik: 'Yüzey Seçenekleri', aciklama: 'Melamin ve laminat kaplama — mat, parlak, dokulu seçenekler.' },
              { baslik: 'Renk & Desen', aciklama: 'Ahşap görünümlü, düz renk, taş ve beton desenler dahil 5.000+ seçenek.' },
              { baslik: 'Ölçü Esnekliği', aciklama: 'Standart ve ısmarlama ölçülerde üretim imkânı.' },
              { baslik: 'Yüksek Dayanım', aciklama: 'Çizilme, darbe ve nem direnci yüksek yüzey kalitesi.' },
              { baslik: 'Kolay İşlenebilirlik', aciklama: 'Kesme, frezeleme ve yapıştırma işlemlerine uygun panel yapısı.' },
              { baslik: 'Üretici Garantisi', aciklama: 'Kastamonu Entegre orijinal ürün, orijinal garanti.' },
            ].map((item) => (
              <div class="border border-gray-100 rounded-lg p-4 bg-gray-50">
                <div class="font-semibold text-gray-900 text-sm mb-1">{item.baslik}</div>
                <div class="text-gray-500 text-xs leading-relaxed">{item.aciklama}</div>
              </div>
            ))}
          </div>

          <!-- Kullanım Alanları -->
          <h2 class="text-2xl font-bold text-primary mb-5">Kullanım Alanları</h2>
          <ul class="space-y-3 mb-10">
            {[
              'Ahşap ve MDF kapı gövdesi kaplaması',
              'Kapı çerçevesi ve pervaz yüzey kaplama',
              'İç kapı kanat yüzeyleri',
              'Dolap ve mobilya kapak paneli',
              'Duvar paneli ve dekoratif yüzey uygulamaları',
            ].map((item) => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-accent shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700 text-sm">{item}</span>
              </li>
            ))}
          </ul>

          <!-- Diğer KE Ürünleri -->
          <h2 class="text-2xl font-bold text-primary mb-5">Diğer Kastamonu Entegre Ürünleri</h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            {[
              { ad: 'Yongalevha (Sunta)', href: '/urunler/kastamonu-entegre/yongalevha' },
              { ad: 'MDF', href: '/urunler/kastamonu-entegre/mdf' },
              { ad: 'MDFLam', href: '/urunler/kastamonu-entegre/mdflam' },
            ].map((item) => (
              <a href={item.href} class="group border border-gray-200 rounded-lg px-4 py-3 text-sm font-medium text-gray-700 hover:border-primary/40 hover:text-primary flex items-center justify-between transition-all">
                {item.ad}
                <svg class="w-4 h-4 text-gray-300 group-hover:text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            ))}
          </div>
        </div>

        <!-- Sağ: CTA -->
        <div class="space-y-5">
          <div class="bg-primary rounded-2xl p-6 text-white">
            <h3 class="text-lg font-bold mb-2">Fiyat Teklifi Alın</h3>
            <p class="text-white/70 text-sm mb-4">
              İhtiyacınızı bildirin, ana bayi fiyatıyla teklif hazırlayalım.
            </p>
            <a
              href="/teklif-al?urun=Kastamonu+Entegre+Kap%C4%B1+Paneli"
              class="block text-center bg-accent hover:bg-accent-dark text-white font-bold px-5 py-3 rounded-lg transition-colors"
            >
              Teklif Al
            </a>
          </div>

          <div class="bg-green-50 border border-green-200 rounded-2xl p-6">
            <h3 class="text-green-800 font-bold mb-2 text-sm">WhatsApp ile İletişim</h3>
            <p class="text-green-700 text-xs mb-4">
              Hızlı yanıt için WhatsApp üzerinden ulaşın.
            </p>
            <a
              href="https://wa.me/905464886737" target="_blank" rel="noopener noreferrer"
              class="block text-center bg-green-600 hover:bg-green-700 text-white font-bold px-5 py-3 rounded-lg transition-colors text-sm"
            >
              WhatsApp — MDF & Panel
            </a>
          </div>

          <div class="bg-wood rounded-2xl p-6">
            <h3 class="text-primary font-bold mb-2 text-sm">Ana Bayi Güvencesi</h3>
            <p class="text-primary/70 text-xs leading-relaxed">
              Kastamonu Entegre Ana Bayisi sıfatıyla orijinal ürün ve üretici garantisi sunuyoruz.
            </p>
          </div>

          <div class="border border-gray-200 rounded-2xl p-6">
            <h3 class="text-gray-800 font-bold mb-3 text-sm">Tüm KE Ürün Kategorileri</h3>
            <ul class="space-y-2">
              {[
                { ad: 'Yongalevha', href: '/urunler/kastamonu-entegre/yongalevha' },
                { ad: 'MDF', href: '/urunler/kastamonu-entegre/mdf' },
                { ad: 'MDFLam', href: '/urunler/kastamonu-entegre/mdflam' },
                { ad: 'Kapı Paneli', href: '/urunler/kastamonu-entegre/kapi-paneli', aktif: true },
              ].map((item) => (
                <li>
                  <a
                    href={item.href}
                    class={`text-sm flex items-center gap-2 ${item.aktif ? 'text-primary font-semibold' : 'text-gray-600 hover:text-primary'} transition-colors`}
                  >
                    <span class={`w-1.5 h-1.5 rounded-full shrink-0 ${item.aktif ? 'bg-accent' : 'bg-gray-300'}`}></span>
                    {item.ad}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Alt CTA -->
  <section class="bg-gray-50 border-t border-gray-200 py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-gray-700 font-medium">Tüm Kastamonu Entegre ürünlerini inceleyin</p>
      <a
        href="/urunler/kastamonu-entegre"
        class="inline-flex items-center gap-2 text-primary font-semibold hover:text-accent transition-colors text-sm"
      >
        Kastamonu Entegre
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
