---

<BaseLayout
  title="Şubelerimiz — 6 Lokasyonda Hizmetinizdeyiz"
  description="Yiğiter Orman Ürünleri 6 şubesi: İstanbul Avrupa Yakası (Başakşehir), Anadolu Yakası (Ümraniye) ve Tosya/Kastamonu'da uzmanlık bazlı hizmet."
>
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

  <!-- Hero -->
  <section class="bg-gray-50 py-12 lg:py-16 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-2">Şubeler</p>
        <h1 class="text-4xl lg:text-5xl font-bold text-primary mb-4 leading-tight">
          6 Şubede Hizmetinizdeyiz
        </h1>
        <p class="text-gray-600 text-lg mb-5">
          İstanbul'un her iki yakası ve Tosya/Kastamonu'da, uzmanlık bazlı şubelerimizle
          20 yılı aşkın süredir yanınızdayız.
        </p>
        <!-- Çalışma Saatleri -->
        <div class="flex flex-wrap gap-3">
          <div class="inline-flex items-center gap-2 bg-primary/10 text-primary text-sm font-semibold px-4 py-2 rounded-full">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Pzt–Cum 08:30–18:00
          </div>
          <div class="inline-flex items-center gap-2 bg-primary/10 text-primary text-sm font-semibold px-4 py-2 rounded-full">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Cumartesi 08:30–15:00
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Filtre Sekmeleri -->
  <section class="bg-white border-b border-gray-200 sticky top-0 z-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex gap-1 overflow-x-auto py-3 scrollbar-none">
        <button
          onclick="filterSube('tumu')"
          id="btn-tumu"
          class="filter-btn active flex-shrink-0 px-4 py-2 rounded-full text-sm font-semibold transition-colors bg-primary text-white"
        >
          Tümü (6)
        </button>
        <button
          onclick="filterSube('istanbul-avrupa')"
          id="btn-istanbul-avrupa"
          class="filter-btn flex-shrink-0 px-4 py-2 rounded-full text-sm font-semibold transition-colors bg-gray-100 text-gray-600 hover:bg-gray-200"
        >
          İstanbul Avrupa Yakası (3)
        </button>
        <button
          onclick="filterSube('istanbul-anadolu')"
          id="btn-istanbul-anadolu"
          class="filter-btn flex-shrink-0 px-4 py-2 rounded-full text-sm font-semibold transition-colors bg-gray-100 text-gray-600 hover:bg-gray-200"
        >
          İstanbul Anadolu Yakası (1)
        </button>
        <button
          onclick="filterSube('tosya')"
          id="btn-tosya"
          class="filter-btn flex-shrink-0 px-4 py-2 rounded-full text-sm font-semibold transition-colors bg-gray-100 text-gray-600 hover:bg-gray-200"
        >
          Tosya / Kastamonu (2)
        </button>
      </div>
    </div>
  </section>

  <!-- Şube Kartları -->
  <section class="py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6" id="subeler-grid">

        {subeler.map((sube) => (
          <div
            class={`sube-kart border rounded-xl p-6 transition-all hover:shadow-md ${sube.ozelVurgu ? 'border-accent/40 ring-1 ring-accent/20' : 'border-gray-200 hover:border-primary/30'}`}
            data-bolge={sube.bölge}
          >
            <!-- Başlık -->
            <div class="mb-4">
              <div class="flex items-center gap-2 mb-2">
                <span class={`text-xs font-bold px-2.5 py-1 rounded-full ${sube.ozelVurgu ? 'bg-accent/10 text-accent' : 'bg-primary/10 text-primary'}`}>
                  {sube.ozelVurgu ? '⭐ ' : ''}{sube.ad}
                </span>
              </div>
              <p class="text-gray-500 text-xs font-medium">{sube.bölgeEtiket}</p>
            </div>

            <!-- Uzmanlık -->
            <p class="text-gray-600 text-xs leading-relaxed mb-4 pb-4 border-b border-gray-100">
              {sube.uzmanlik}
            </p>

            <!-- Adres -->
            <div class="flex items-start gap-2 mb-3">
              <svg class="w-4 h-4 text-gray-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <div>
                <p class="text-gray-700 text-xs leading-relaxed">{sube.adres}</p>
                <p class="text-gray-400 text-xs">{sube.şehir}</p>
              </div>
            </div>

            <!-- Telefonlar -->
            <div class="space-y-1.5 mb-3">
              {sube.telefonlar.map((tel) => (
                <div class="flex items-center gap-2">
                  <svg class="w-3.5 h-3.5 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                  <a href={tel.href} class="text-sm text-gray-800 hover:text-accent transition-colors font-medium">{tel.numara}</a>
                  <span class="text-gray-300 text-xs">{tel.tip}</span>
                </div>
              ))}
            </div>

            <!-- E-posta -->
            <div class="flex items-center gap-2 mb-4">
              <svg class="w-3.5 h-3.5 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <div class="flex flex-col gap-0.5">
                <a href={`mailto:${sube.eposta}`} class="text-sm text-gray-700 hover:text-accent transition-colors">{sube.eposta}</a>
                {sube.eposta2 && <a href={`mailto:${sube.eposta2}`} class="text-sm text-gray-700 hover:text-accent transition-colors">{sube.eposta2}</a>}
              </div>
            </div>

            <!-- Çalışma Saatleri -->
            <div class="flex items-center gap-2 mb-5 text-xs text-gray-500">
              <svg class="w-3.5 h-3.5 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              Pzt–Cum 08:30–18:00 &nbsp;|&nbsp; Cmt 08:30–15:00
            </div>

            <!-- WhatsApp Butonu -->
            {sube.whatsapp && (
              <a
                href={sube.whatsapp}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center gap-2 bg-[#25D366] hover:bg-[#1da851] text-white text-sm font-semibold px-4 py-2.5 rounded-lg transition-colors w-full"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                WhatsApp ile Yaz
              </a>
            )}
          </div>
        ))}

      </div>

      <!-- Boş Sonuç Mesajı -->
      <div id="bos-sonuc" class="hidden text-center py-16 text-gray-400">
        <p class="text-lg font-medium">Bu bölgede şube bulunmuyor.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-primary py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl lg:text-3xl font-bold text-white mb-3">
        Hangi Ürüne İhtiyacınız Var?
      </h2>
      <p class="text-white/70 text-base mb-6 max-w-xl mx-auto">
        Size en yakın şubemiz veya uzman ekibimiz yardımcı olsun.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/iletisim/teklif-al"
          class="inline-flex items-center justify-center gap-2 bg-accent hover:bg-amber-600 text-white font-bold px-6 py-3 rounded-lg transition-colors"
        >
          Teklif Al
        </a>
        <a
          href="https://wa.me/905415157667?text=Merhaba%2C%20Yi%C4%9Fiter%20Orman%20%C3%9Cr%C3%BCnleri%27ne%20ula%C5%9Fmak%20istiyorum."
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-[#25D366] hover:bg-[#1da851] text-white font-semibold px-6 py-3 rounded-lg transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  function filterSube(bolge: string) {
    const kartlar = document.querySelectorAll<HTMLElement>('.sube-kart');
    const btnler = document.querySelectorAll<HTMLElement>('.filter-btn');
    const bosMsg = document.getElementById('bos-sonuc');

    btnler.forEach(btn => {
      btn.classList.remove('bg-primary', 'text-white');
      btn.classList.add('bg-gray-100', 'text-gray-600');
    });

    const aktifBtn = document.getElementById(`btn-${bolge}`);
    if (aktifBtn) {
      aktifBtn.classList.remove('bg-gray-100', 'text-gray-600');
      aktifBtn.classList.add('bg-primary', 'text-white');
    }

    let gorunenSayi = 0;
    kartlar.forEach(kart => {
      const kartBolge = kart.dataset.bolge;
      if (bolge === 'tumu' || kartBolge === bolge) {
        kart.style.display = '';
        gorunenSayi++;
      } else {
        kart.style.display = 'none';
      }
    });

    if (bosMsg) {
      bosMsg.classList.toggle('hidden', gorunenSayi > 0);
    }
  }
  (window as any).filterSube = filterSube;
</script>
