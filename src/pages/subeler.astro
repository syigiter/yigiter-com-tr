    "description": s.uzmanlik,
    "url": "https://yigiter.com.tr/subeler",
    "telephone": s.telefonlar[0].href.replace('tel:', ''),
    "email": s.eposta,
    "openingHours": ["Mo-Fr 08:30-18:00", "Sa 08:30-15:00"],
    "address": {
      "@type": "PostalAddress",
      "streetAddress": s.adres,
      "addressLocality": s.şehir.split(' / ')[0],
      "addressRegion": s.şehir.split(' / ')[1] ?? s.şehir,
      "addressCountry": "TR"
    },
    "parentOrganization": {
