---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Teklif Al"
  description="Kapı, kasa, pervaz, MDF panel ve orman ürünleri ihtiyaçlarınız için Yiğiter Orman Ürünleri'nden teklif alın."
>
  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-2 text-sm">
        <a href="/" class="text-primary hover:underline">Anasayfa</a>
        <span class="text-gray-300">/</span>
        <span class="text-gray-600">Teklif Al</span>
      </div>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-primary text-white py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <h1 class="text-4xl lg:text-5xl font-bold mb-4 leading-tight">
          Teklif Al
        </h1>
        <p class="text-white/85 text-lg">
          Kapı, kasa, pervaz, MDF panel ve orman ürünleri ihtiyaçlarınız için hızlı teklif talebi oluşturun.
        </p>
      </div>
    </div>
  </section>

  <!-- Form Section -->
  <section class="py-16 lg:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <form
        id="teklif-form"
        class="space-y-6"
      >
        <input type="hidden" name="access_key" value="7fe6232c-6b7a-464a-afe1-265dca4a2472" />
        <input type="hidden" name="subject" value="Yiğiter — Yeni Teklif Talebi" />
        <input type="hidden" name="from_name" value="Yiğiter Web Sitesi" />
        <input type="hidden" name="botcheck" value="" style="display:none" />

        <!-- Şirket Bilgileri -->
        <div class="bg-gray-50 border border-gray-200 rounded-xl p-6">
          <h2 class="text-lg font-bold text-primary mb-4">Şirket Bilgileri</h2>

          <div class="space-y-4">
            <div>
              <label for="company_name" class="block text-sm font-medium text-gray-900 mb-1">
                Şirket Adı <span class="text-accent-dark">*</span>
              </label>
              <input
                type="text"
                id="company_name"
                name="company_name"
                required
                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
                placeholder="Şirketinizin adı"
              />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="contact_name" class="block text-sm font-medium text-gray-900 mb-1">
                  İletişim Kişisi <span class="text-accent-dark">*</span>
                </label>
                <input
                  type="text"
                  id="contact_name"
                  name="contact_name"
                  required
                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
                  placeholder="Adı, soyadı"
                />
              </div>

              <div>
                <label for="phone" class="block text-sm font-medium text-gray-900 mb-1">
                  Telefon <span class="text-accent-dark">*</span>
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  required
                  inputmode="tel"
                  autocomplete="tel"
                  maxlength="19"
                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
                  placeholder="+90 (5XX) XXX XX XX"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="email" class="block text-sm font-medium text-gray-900 mb-1">
                  E-posta <span class="text-accent-dark">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
                  placeholder="example@example.com"
                />
              </div>

              <div>
            <label for="city" class="block text-sm font-medium text-gray-900 mb-1">
                  Şehir
                </label>
                <input
                  type="text"
                  id="city"
                  name="city"
                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
                  placeholder="İstanbul"
                />
              </div>
            </div>
          </div>
        </div>

        <!-- Ürün Bilgileri -->
        <div class="bg-gray-50 border border-gray-200 rounded-xl p-6">
          <h2 class="text-lg font-bold text-primary mb-4">Ürün Bilgileri</h2>

          <div class="space-y-4">
            <div>
              <label for="product_category" class="block text-sm font-medium text-gray-900 mb-1">
                Ürün Kategorisi <span class="text-accent-dark">*</span>
              </label>
              <select
                id="product_category"
                name="product_category"
                required
                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
              >
                <option value="">Seçiniz...</option>
                <option value="kastamonu-entegre">Kastamonu Entegre Ürünleri</option>
                <option value="genc-boya">Genç Boya</option>
                <option value="melamin-kapi-yuzeyi">Melamin Kapı Yüzeyleri</option>
                <option value="kapi-kasasi-pervaz">Kapı Kasası & Pervaz</option>
                <option value="kagit-dolgu">Kağıt Dolgu Malzemesi</option>
                <option value="pvc-film">PVC Film</option>
                <option value="diger">Diğer</option>
              </select>
            </div>

            <div>
              <label for="product_details" class="block text-sm font-medium text-gray-900 mb-1">
                Ürün Detayları <span class="text-accent-dark">*</span>
              </label>
              <textarea
                id="product_details"
                name="product_details"
                required
                rows="4"
                maxlength="2000"
                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
                placeholder="Talep ettiğiniz ürün, miktar, özellikleri, özel gereksinimler vb. açıklayın..."
              ></textarea>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="quantity" class="block text-sm font-medium text-gray-900 mb-1">
                  Miktar
                </label>
                <input
                  type="text"
                  id="quantity"
                  name="quantity"
                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
                  placeholder="örn. 100 m³, 50 paket, vb."
                />
              </div>

              <div>
            <label for="delivery_date" class="block text-sm font-medium text-gray-900 mb-1">
                  İhtiyaç Tarihi
                </label>
                <input
                  type="date"
                  id="delivery_date"
                  name="delivery_date"
                  class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
                />
              </div>
            </div>
          </div>
        </div>

        <!-- Ek Bilgiler -->
        <div class="bg-gray-50 border border-gray-200 rounded-xl p-6">
          <h2 class="text-lg font-bold text-primary mb-4">Ek Bilgiler</h2>

          <div class="space-y-4">
            <div>
              <label for="delivery_location" class="block text-sm font-medium text-gray-900 mb-1">
                Teslimat Yeri
              </label>
              <input
                type="text"
                id="delivery_location"
                name="delivery_location"
                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
                placeholder="Depo, fabrika, şantiye veya teslimat adresi"
              />
            </div>

            <fieldset>
              <legend class="block text-sm font-medium text-gray-900 mb-2">Talep Türü</legend>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                {['Numune', 'Katalog', 'Fiyat Listesi'].map((item) => (
                  <label class="flex items-center gap-2 rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm text-gray-700">
                    <input type="checkbox" name="request_type" value={item} class="rounded border-gray-300 text-primary focus:ring-primary" />
                    {item}
                  </label>
                ))}
              </div>
            </fieldset>

            <div>
            <label for="message" class="block text-sm font-medium text-gray-900 mb-1">
              Mesajınız
            </label>
            <textarea
              id="message"
              name="message"
              rows="3"
              maxlength="2000"
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
              placeholder="Eklemek istediğiniz başka bilgiler varsa yazabilirsiniz..."
            ></textarea>
            </div>
          </div>
        </div>

        <!-- Checkbox: İletişim İzni -->
        <div class="flex items-start gap-3">
          <input
            type="checkbox"
            id="contact_consent"
            name="contact_consent"
            required
            class="mt-1 rounded border-gray-300 text-primary focus:ring-primary"
          />
          <label for="contact_consent" class="text-sm text-gray-700">
            Kişisel verilerimin, teklif talebimin değerlendirilmesi ve tarafıma dönüş yapılması amacıyla işlenmesine ilişkin
            <a href="/kvkk" target="_blank" rel="noopener noreferrer" class="font-semibold text-primary hover:text-accent-dark underline underline-offset-2">
              KVKK ve Gizlilik Politikası
            </a>’nı okudum ve kabul ediyorum. <span class="text-accent-dark">*</span>
          </label>
        </div>

        <!-- Submit Button -->
        <div class="flex gap-3">
          <button
            type="submit"
            id="submit-btn"
            class="flex-1 bg-[#9A3412] hover:bg-[#7C2D12] text-white font-bold px-6 py-3 rounded-lg transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
          >
            <span id="submit-label">Teklif İste</span>
            <span id="submit-loading" class="hidden">Gönderiliyor...</span>
          </button>
          <a
            href="/iletisim"
            class="flex-1 text-center border border-gray-300 text-gray-700 hover:bg-gray-100 hover:text-gray-900 font-semibold px-6 py-3 rounded-lg transition-colors"
          >
            İptal
          </a>
        </div>

        <!-- Not -->
        <p class="text-center text-gray-700 text-xs">
          Toptan satış ve proje bazlı fiyatlandırma için teklif alabilirsiniz. En kısa sürede sizinle iletişime geçeceğiz.
        </p>
      </form>

    </div>
  </section>

  <!-- Alt Bilgi -->
  <section class="bg-gray-50 py-12 lg:py-16 border-t border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="text-2xl font-bold text-primary mb-4">Hızlı İletişim Kanalları</h2>
        <p class="text-gray-600 mb-6">
          Acil talebiniz varsa aşağıdaki kanallardan doğrudan bize ulaşabilirsiniz.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href="https://wa.me/905319313310?text=Merhaba%2C%20Yi%C4%9Fiter%20Orman%20%C3%9Cr%C3%BCnleri%27ne%20ula%C5%9Fmak%20istiyorum."
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 bg-green-700 hover:bg-green-800 text-white font-semibold px-4 py-2.5 rounded-lg transition-colors text-sm"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp ile Yaz
          </a>
          <a
            href="tel:+902126702025"
            class="flex items-center justify-center gap-2 bg-primary hover:bg-primary-light text-white font-semibold px-4 py-2.5 rounded-lg transition-colors text-sm"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Telefon ile Ara
          </a>
        </div>
      </div>
    </div>
  </section>


<script>
  // ?urun= pre-fill
  const params = new URLSearchParams(window.location.search);
  const urun = params.get('urun');
  if (urun) {
    const decoded = decodeURIComponent(urun);
    const heroP = document.querySelector('section.bg-primary p.text-white\\/75');
    if (heroP) heroP.textContent = `"${decoded}" için teklif talebinizi aşağıdaki formu doldurarak iletebilirsiniz.`;
    const details = document.getElementById('product_details') as HTMLTextAreaElement | null;
    if (details && !details.value) details.value = decoded;
    const select = document.getElementById('product_category') as HTMLSelectElement | null;
    if (select) {
      const lower = decoded.toLowerCase();
      let val = '';
      if (lower.includes('kastamonu') || lower.includes('sunta') || lower.includes('mdf') || lower.includes('yongalevha')) val = 'kastamonu-entegre';
      else if (lower.includes('boya') || lower.includes('vernik') || lower.includes('astar')) val = 'genc-boya';
      else if (lower.includes('melamin')) val = 'melamin-kapi-yuzeyi';
      else if (lower.includes('kasa') || lower.includes('pervaz')) val = 'kapi-kasasi-pervaz';
      else if (lower.includes('kağıt') || lower.includes('honeycomb') || lower.includes('petek')) val = 'kagit-dolgu';
      else if (lower.includes('pvc')) val = 'pvc-film';
      if (val) select.value = val;
    }
  }

  // Web3Forms submit
  const form = document.getElementById('teklif-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const submitLabel = document.getElementById('submit-label');
  const submitLoading = document.getElementById('submit-loading');
  const deliveryDate = document.getElementById('delivery_date') as HTMLInputElement | null;
  const phoneInput = document.getElementById('phone') as HTMLInputElement | null;

  if (deliveryDate) {
    deliveryDate.min = new Date().toISOString().slice(0, 10);
  }

  phoneInput?.addEventListener('input', () => {
    const digits = phoneInput.value.replace(/\D/g, '').replace(/^90/, '').slice(0, 10);
    const part1 = digits.slice(0, 3);
    const part2 = digits.slice(3, 6);
    const part3 = digits.slice(6, 8);
    const part4 = digits.slice(8, 10);
    let formatted = '+90';
    if (part1) formatted += ` (${part1}`;
    if (part1.length === 3) formatted += ')';
    if (part2) formatted += ` ${part2}`;
    if (part3) formatted += ` ${part3}`;
    if (part4) formatted += ` ${part4}`;
    phoneInput.value = formatted;
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn || !form) return;

    submitBtn.disabled = true;
    submitLabel?.classList.add('hidden');
    submitLoading?.classList.remove('hidden');

    const data = new FormData(form);
    const json = Object.fromEntries(data.entries());

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(json),
      });
      const result = await res.json();
      if (result.success) {
        window.location.href = '/tesekkurler';
      } else {
        alert('Gönderim sırasında bir hata oluştu. Lütfen tekrar deneyin veya WhatsApp ile iletişime geçin.');
        submitBtn.disabled = false;
        submitLabel?.classList.remove('hidden');
        submitLoading?.classList.add('hidden');
      }
    } catch {
      alert('Bağlantı hatası. Lütfen tekrar deneyin.');
      submitBtn.disabled = false;
      submitLabel?.classList.remove('hidden');
      submitLoading?.classList.add('hidden');
    }
  });
</script>
</BaseLayout>
