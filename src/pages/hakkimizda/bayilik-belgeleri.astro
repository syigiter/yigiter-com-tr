---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Yetkili Bayiliklerimiz"
  description="Yiğiter Orman Ürünleri — Kastamonu Entegre Ana Bayisi, Genç Boya Distribütörü. Orijinal ürün ve üretici güvencesi."
>
  <!-- Breadcrumb -->
  <div class="bg-gray-50 border-b border-gray-200 py-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-2 text-sm">
        <a href="/" class="text-primary hover:underline">Anasayfa</a>
        <span class="text-gray-300">/</span>
        <a href="/hakkimizda" class="text-primary hover:underline">Hakkımızda</a>
        <span class="text-gray-300">/</span>
        <span class="text-gray-600">Bayilik Belgeleri</span>
      </div>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-primary text-white py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="text-4xl lg:text-5xl font-bold mb-6 leading-tight">
          Yetkili Bayi ve<br />
          Distribütörlüklerimiz
        </h1>
        <p class="text-white/75 text-lg">
          Kastamonu Entegre, Genç Boya ve ithalat yetkilerimizle müşterilerimize orijinal, garantili ürün sunuyoruz.
        </p>
      </div>
    </div>
  </section>

  <!-- İçerik -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 mb-16">

        <!-- Sol: Başlık ve Açıklama -->
        <div class="lg:col-span-2">
          <h2 class="text-3xl font-bold text-primary mb-6">Orijinal Ürün Garantisi</h2>

          <p class="text-gray-600 text-base leading-relaxed mb-6">
            Tüm ürünlerimiz <strong class="text-gray-800">orijinal, garantili ve üretici güvencesi altındadır.</strong>
            Aşağıdaki başlı marka ve distribütörlüklerin <strong class="text-gray-800">yetkili bayi veya distribütörü</strong>
            olarak hizmet veriyoruz. Belgelerimiz müşterilerimizin güvenini sağlamak ve orijinal ürün sunmamızı
            doğrulamak için hemen başında sunmaktadır.
          </p>

          <p class="text-gray-600 text-base leading-relaxed mb-8">
            Müşterilerimiz bizden alacakları ürünlerin <strong class="text-gray-800">taklit olmadığını,</strong>
            üretici tarafından garantilendğini ve destek alabileceklerini emin olabilirler.
          </p>

          <div class="bg-primary/5 border border-primary/20 rounded-lg p-6 mb-8">
            <h3 class="font-bold text-gray-900 mb-3">Yetkilendirmelerimiz</h3>
            <ul class="space-y-2">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-accent mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700 text-sm"><strong class="text-gray-900">Kastamonu Entegre Ana Bayisi</strong> — Yongalevha, MDF, MDFLam, Panel Ürünleri</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-accent mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700 text-sm"><strong class="text-gray-900">Genç Boya İstanbul Anadolu Yakası Distribütörü</strong> — Mobilya ve Ahşap Boyası Ürünleri</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-accent mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700 text-sm"><strong class="text-gray-900">Genç Boya Tosya Bayisi</strong> — Karadeniz Bölgesi</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-accent mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700 text-sm"><strong class="text-gray-900">Melamin Kaplı Kapı Yüzeyi İthalatçısı</strong> — Yurt Dışından Seçilmiş Kaliteli Ürünler</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Sağ: İstatistikler -->
        <div class="space-y-4">
          <div class="bg-accent rounded-xl p-6 text-white">
            <div class="text-4xl font-bold mb-1">100%</div>
            <div class="text-white/90 text-sm font-medium">Orijinal Ürün</div>
            <p class="text-white/70 text-xs mt-3 leading-relaxed">
              Tüm ürünlerimiz orijinal ve üretici garantili.
            </p>
          </div>

          <div class="bg-primary rounded-xl p-6 text-white">
            <div class="text-4xl font-bold mb-1">4</div>
            <div class="text-white/90 text-sm font-medium">Yetkili Bayi</div>
            <p class="text-white/70 text-xs mt-3 leading-relaxed">
              Tanınmış markaların yetkili tedarikçisi.
            </p>
          </div>

          <div class="bg-wood rounded-xl p-6 text-primary">
            <div class="text-4xl font-bold mb-1">20+</div>
            <div class="text-primary/80 text-sm font-medium">Yıllık Güven</div>
            <p class="text-primary/60 text-xs mt-3 leading-relaxed">
              İki kuşaktır müşterilerin güveni.
            </p>
          </div>
        </div>
      </div>

      <!-- Yetkililik Kartları -->
      <h2 class="text-3xl font-bold text-primary mb-8">Yetkili Olduğumuz Markalar</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">

        <!-- Kastamonu Entegre Ana Bayi -->
        <div class="border border-gray-200 rounded-2xl p-6 hover:border-primary/30 hover:shadow-md transition-all">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
            </div>
            <div>
              <span class="inline-block bg-primary/10 text-primary text-xs font-bold px-2 py-0.5 rounded-full mb-1">Ana Bayi</span>
              <h3 class="text-lg font-bold text-gray-900">Kastamonu Entegre</h3>
            </div>
          </div>
          <div class="space-y-3 text-sm">
            <div class="flex gap-2">
              <span class="text-gray-400 w-24 flex-shrink-0">Yetki Türü</span>
              <span class="text-gray-800 font-medium">Ana Bayilik</span>
            </div>
            <div class="flex gap-2">
              <span class="text-gray-400 w-24 flex-shrink-0">Kapsam</span>
              <span class="text-gray-800">Yongalevha (Sunta), MDF, MDFLam ve tüm panel ürünleri</span>
            </div>
            <div class="flex gap-2">
              <span class="text-gray-400 w-24 flex-shrink-0">Bölge</span>
              <span class="text-gray-800">Türkiye geneli sevkiyat</span>
            </div>
            <div class="flex gap-2">
              <span class="text-gray-400 w-24 flex-shrink-0">Avantaj</span>
              <span class="text-gray-800">Stoktan teslimat, rekabetçi toptan fiyat, orijinal ürün</span>
            </div>
          </div>
        </div>

        <!-- Genç Boya Distribütör -->
        <div class="border border-gray-200 rounded-2xl p-6 hover:border-primary/30 hover:shadow-md transition-all">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
              </svg>
            </div>
            <div>
              <span class="inline-block bg-primary/10 text-primary text-xs font-bold px-2 py-0.5 rounded-full mb-1">Distribütör</span>
              <h3 class="text-lg font-bold text-gray-900">Genç Boya — İstanbul Anadolu Yakası</h3>
            </div>
          </div>
          <div class="space-y-3 text-sm">
            <div class="flex gap-2">
              <span class="text-gray-400 w-24 flex-shrink-0">Yetki Türü</span>
              <span class="text-gray-800 font-medium">Bölge Distribütörlüğü</span>
            </div>
            <div class="flex gap-2">
              <span class="text-gray-400 w-24 flex-shrink-0">Kapsam</span>
              <span class="text-gray-800">Boya, vernik, astar, sertleştirici, tiner — mobilya ve ahşap boyası ürünleri</span>
            </div>
            <div class="flex gap-2">
              <span class="text-gray-400 w-24 flex-shrink-0">Bölge</span>
              <span class="text-gray-800">İstanbul Anadolu Yakası</span>
            </div>
            <div class="flex gap-2">
              <span class="text-gray-400 w-24 flex-shrink-0">Şube</span>
              <span class="text-gray-800">Ümraniye — Keyap Sanayi Sitesi</span>
            </div>
          </div>
        </div>

        <!-- Genç Boya Bayi (Avrupa Yakası) -->
        <div class="border border-gray-200 rounded-2xl p-6 hover:border-primary/30 hover:shadow-md transition-all">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
              </svg>
            </div>
            <div>
              <span class="inline-block bg-primary/10 text-primary text-xs font-bold px-2 py-0.5 rounded-full mb-1">Bayi</span>
              <h3 class="text-lg font-bold text-gray-900">Genç Boya — İstanbul Avrupa Yakası</h3>
            </div>
          </div>
          <div class="space-y-3 text-sm">
            <div class="flex gap-2">
              <span class="text-gray-400 w-24 flex-shrink-0">Yetki Türü</span>
              <span class="text-gray-800 font-medium">Bölge Bayiliği</span>
            </div>
            <div class="flex gap-2">
              <span class="text-gray-400 w-24 flex-shrink-0">Kapsam</span>
              <span class="text-gray-800">Genç Boya ürün portföyünün tamamı</span>
            </div>
            <div class="flex gap-2">
              <span class="text-gray-400 w-24 flex-shrink-0">Bölge</span>
              <span class="text-gray-800">İstanbul Avrupa Yakası</span>
            </div>
            <div class="flex gap-2">
              <span class="text-gray-400 w-24 flex-shrink-0">Şube</span>
              <span class="text-gray-800">Başakşehir — İkitelli Keresteciler Sitesi, 18. Blok</span>
            </div>
          </div>
        </div>

        <!-- Genç Boya Bayi (Tosya) -->
        <div class="border border-gray-200 rounded-2xl p-6 hover:border-primary/30 hover:shadow-md transition-all">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
              </svg>
            </div>
            <div>
              <span class="inline-block bg-primary/10 text-primary text-xs font-bold px-2 py-0.5 rounded-full mb-1">Bayi</span>
              <h3 class="text-lg font-bold text-gray-900">Genç Boya — Tosya</h3>
            </div>
          </div>
          <div class="space-y-3 text-sm">
            <div class="flex gap-2">
              <span class="text-gray-400 w-24 flex-shrink-0">Yetki Türü</span>
              <span class="text-gray-800 font-medium">Bölge Bayiliği</span>
            </div>
            <div class="flex gap-2">
              <span class="text-gray-400 w-24 flex-shrink-0">Kapsam</span>
              <span class="text-gray-800">Genç Boya ürün portföyünün tamamı</span>
            </div>
            <div class="flex gap-2">
              <span class="text-gray-400 w-24 flex-shrink-0">Bölge</span>
              <span class="text-gray-800">Tosya ve Karadeniz çevresi</span>
            </div>
            <div class="flex gap-2">
              <span class="text-gray-400 w-24 flex-shrink-0">Şube</span>
              <span class="text-gray-800">Tosya Merkez — Harsat Mahallesi Sanayi Sokak</span>
            </div>
          </div>
        </div>

        <!-- Melamin Kapı Yüzeyi İthalatçısı -->
        <div class="border border-accent/30 rounded-2xl p-6 hover:border-accent/50 hover:shadow-md transition-all md:col-span-2">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <span class="inline-block bg-accent/10 text-accent text-xs font-bold px-2 py-0.5 rounded-full mb-1">İthalatçı</span>
              <h3 class="text-lg font-bold text-gray-900">Melamin Kaplı Kapı Yüzeyi</h3>
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
            <div class="flex gap-2">
              <span class="text-gray-400 w-24 flex-shrink-0">Yetki Türü</span>
              <span class="text-gray-800 font-medium">Doğrudan İthalat</span>
            </div>
            <div class="flex gap-2">
              <span class="text-gray-400 w-24 flex-shrink-0">Menşe</span>
              <span class="text-gray-800">Yurt dışı — seçilmiş tedarikçiler</span>
            </div>
            <div class="flex gap-2">
              <span class="text-gray-400 w-24 flex-shrink-0">Kapsam</span>
              <span class="text-gray-800">Melamin kaplı kapı yüzeyleri — geniş renk ve desen kataloğu</span>
            </div>
            <div class="flex gap-2">
              <span class="text-gray-400 w-24 flex-shrink-0">Avantaj</span>
              <span class="text-gray-800">Aracısız ithalat, rekabetçi fiyat, stoktan teslimat</span>
            </div>
          </div>
        </div>

      </div>

      <!-- Alt Bölümler -->
      <div class="mt-12 pt-8 border-t border-gray-200">
        <h3 class="text-lg font-bold text-primary mb-4">Daha Fazla Bilgi</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <a
            href="/hakkimizda/sirketimiz"
            class="group border border-gray-200 rounded-lg p-4 hover:border-primary/40 hover:shadow-sm transition-all"
          >
            <div class="flex items-center justify-between">
              <h4 class="font-semibold text-gray-900 group-hover:text-primary transition-colors">Şirket Hikayesi</h4>
              <svg class="w-4 h-4 text-gray-300 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </a>
          <a
            href="/iletisim"
            class="group border border-gray-200 rounded-lg p-4 hover:border-primary/40 hover:shadow-sm transition-all"
          >
            <div class="flex items-center justify-between">
              <h4 class="font-semibold text-gray-900 group-hover:text-primary transition-colors">Bize Ulaşın</h4>
              <svg class="w-4 h-4 text-gray-300 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
