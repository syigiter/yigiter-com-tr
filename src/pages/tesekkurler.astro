---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Teşekkürler"
  description="Teklif talebiniz alındı. Yiğiter Orman Ürünleri ekibi en kısa sürede sizinle iletişime geçecek."
>
  <section class="min-h-[70vh] flex items-center justify-center py-20">
    <div class="max-w-lg mx-auto px-4 text-center">

      <!-- İkon -->
      <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <h1 class="text-3xl font-bold text-primary mb-3">Talebiniz Alındı!</h1>
      <p class="text-gray-600 text-lg mb-2">
        Teklif formunuz başarıyla iletildi.
      </p>
      <p class="text-gray-500 text-base mb-10">
        Ekibimiz en kısa sürede — genellikle <strong class="text-gray-700">aynı iş günü içinde</strong> — sizinle iletişime geçecek.
      </p>

      <!-- Hızlı İletişim -->
      <div class="bg-gray-50 border border-gray-200 rounded-2xl p-6 mb-8 text-left">
        <p class="text-sm font-semibold text-gray-700 mb-4">Acil ihtiyaç varsa doğrudan ulaşın:</p>
        <div class="space-y-3">
          <a
            href="https://wa.me/905415157667?text=Merhaba%2C%20teklif%20formu%20g%C3%B6nderdim%2C%20h%C4%B1zl%C4%B1%20bilgi%20almak%20istiyorum."
            target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-3 bg-green-600 hover:bg-green-700 text-white font-semibold px-4 py-3 rounded-lg transition-colors text-sm"
          >
            <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp ile Yaz
          </a>
          <a
            href="tel:+905415157667"
            class="flex items-center gap-3 border border-gray-200 hover:border-primary/40 text-gray-700 hover:text-primary font-medium px-4 py-3 rounded-lg transition-colors text-sm"
          >
            <svg class="w-5 h-5 shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            0541 515 7667 — Kapı Ürünleri
          </a>
        </div>
      </div>

      <!-- Geri dön -->
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary/90 text-white font-semibold px-6 py-3 rounded-lg transition-colors text-sm"
        >
          Ana Sayfaya Dön
        </a>
        <a
          href="/urunler/"
          class="inline-flex items-center justify-center gap-2 border border-gray-200 hover:border-primary/40 text-gray-700 hover:text-primary font-medium px-6 py-3 rounded-lg transition-colors text-sm"
        >
          Ürünlere Göz At
        </a>
      </div>

    </div>
  </section>
</BaseLayout>
